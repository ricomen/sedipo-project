              }
            })
            .catch(error => {
              console.log(error.response)
            })

        },

            on_select_role(){
              if(this.selectedRole == ''){
                this.selectedRole = this.role_id 

              }
          }



  },



	template: `
  <div  v-if="role_privileges.accountedit == 2 || account_id==0 ">
  <div><navigation></navigation><h3>Редактирование записи {{ this.login }}</h3> 

  <h4 style="text-align: center; color: red;">{{message}}<!--{{this.roles}} TUT {{ this.role_id }}--></h4>

{{info}}

<div align="left">
<div class="container">

  <div class="mb-2 row">	
  <label for="input_fullname"  class="form-label col-sm-2"   >Имя пользователя</label>
    <input v-model="fullname"   class="form-control col" id="input_fullname"   type="text"  >
  </div>

  <div class="mb-2 row">	
    <label for="input_contact" class="form-label col-sm-2">email</label>
    <input v-model="email"  class="form-control col" id="input_contact"    type="text"  >
  </div>

  <div class="mb-2 row">	
      <label for="input_login" class="form-label col-sm-2">login</label>
      <input v-model="login"   class="form-control col" id="input_login"   type="text"  >
  </div>

  <div v-if="role_privileges.rolelist == 2" class="mb-2 row">
  <label for="input_login" class="form-label col-sm-2">Роль</label>	
    <select v-model="selectedRole" class="form-control col" @change="on_select_role()">
      <option disabled value="">Выберите роль</option>
      <option   v-for="item in roles.list"  :key="item.role_id" :value="item.role_id">
        {{ item.role_name }}
      </option>
    </select>
    <!--<p>Выбрано: {{ selectedRole }}</p>-->
  </div>




  <br /><hr />
  <h4>Сменить пароль </h4> 
  <div class="mb-2 row">	
      <label for="input_password0" class="form-label col-sm-2">Текущий пароль</label>
      <input v-model="password0"  class="form-control col" id="input_password0"    type="password"  >

   </div>

  <div class="mb-2 row">	
      <label for="input_password1" class="form-label col-sm-2">Новый пароль</label>
      <input v-model="password1"  class="form-control col" id="input_password1"    type="password"  >

   </div>

  <div class="mb-2 row">	
      <label for="input_password2" class="form-label col-sm-2">Новый пароль повторно</label>
      <input v-model="password2"  class="form-control col" id="input_password2"    type="password"  >

   </div>


  <div v-if="role_privileges.accountslist != 0" class="mb-2">	
    <div align="right">
    <button v-if="account_id>0"   class="btn btn-primary"    @click="accountSave()"> Сохранить </button>
    <button v-if="account_id==0 "  class="btn btn-primary"    @click="accountCreate()"> Добавить учетную запись </button>
      &nbsp<router-link to="/accountslist" ><button class="btn btn-outline-primary">Отмена</button></router-link>
    </div>
  </div>
  <div v-if="role_privileges.accountslist == 0" class="mb-2">	
    <div align="right">
    <button v-if="account_id>0"   class="btn btn-primary"    @click="accountSave()"> Сохранить </button>
    <button v-if="account_id==0 "  class="btn btn-primary"    @click="accountCreate()"> Добавить учетную запись </button>
      &nbsp<router-link to="/" ><button class="btn btn-outline-primary">Отмена</button></router-link>
    </div>
  </div>
 </div>




        </div>
	</div>
</div>`

};




