   mounted() {
//    updated() {
    this.role_privileges =  session_role_privileges
    this.account_id = Number(this.$route.params.accountid)
    if(this.account_id > 0 ){
     axios
      .post(JsonApiURL+'api/account1_json.php', {object: {objectId: this.account_id, sessionId: session_t.sessionId } }, {withCredentials: true})
      .then(response => { 
            this.info = response.data
            this.role = this.info.role
            this.role_id = this.info.result.role_id
            this.selectedRole = this.role_id 
            this.fullname = this.info.result.fullname
            this.email = this.info.result.email
            this.login = this.info.result.login
       })
      .catch(error => {
              console.log(error.response)
            })

    }

    axios
      .post(JsonApiURL+'api/role_json.php', {list: { sessionId: session_t.sessionId }}, {withCredentials: true})
      .then(response => { 

            this.roles = response.data
       })
      .catch(error => {
              console.log(error.response)
            })

  },


  methods: {
        accountSave() {
	    axios
            .post(JsonApiURL+'api/account1_json.php', {update: {objectId: this.account_id,  fullname: this.fullname,  email: this.email, login: this.login, password0: this.password0, password1: this.password1, password2: this.password2, role_id: this.selectedRole,   sessionId: session_t.sessionId } }, {withCredentials: true})
            .then(response => {
              console.log(response)
    	      //this.info9 = response.data

              if(response.data.status==0) {
                   this.$router.push({ path: '/accountslist'}) 

