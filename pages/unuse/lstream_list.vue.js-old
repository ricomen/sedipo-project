          <th scope="col"><div align="center" style="margin-right: 0px; font-size: smaller;">Cписок обучающихся </th>

          <!--<th  v-if="role!='counterparty'"  scope="col"> <div style="float: right"><router-link  :to="{ name: 'group_edit', params: {groupid: 0, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}"   title="Добавить группу" ><b style=" font-size: larger;"><i class="far fa-plus-square"></i></b></router-link ></div>  </th>-->
        </tr>
      </thead>
     <tbody>   
