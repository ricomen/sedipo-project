var LstreamList = {
  data: function () {
    return {
      role: '',
      moodle_path: '',
      info: [],
      info2: [],
      info3: [],
      info9: [],
      order_id: 0,
      make: 0,
      a_counterparty_id: 0,
      status: 0,
      status_array:  [], 
      DPO: DPO,
      message: '',
      datesearch: '',
      datesearch2: '',
      namesearch: '',
      counterpartysearch: 0,
      numPages: 0,
      page: 1,
      date_begin: 0,
      date_end: 0,
      date_protocol: 0,
      modal_objectId: 0,
      modal_date_begin: '',
      modal_date_begin2: '',
      modal_date_end: '',
      modal_date_protocol: '',
      modal_days: '',

      modal_lstream_id: 0,
      modal_name: '',
      modal_main_teacher_id: 0,

      print_v: 'true',
      mon_arr: [{name: 'Январь', t_class: 'nav-link'}, {name: 'Февраль', t_class: 'nav-link'}, {name: 'Март', t_class: 'nav-link'}, {name: 'Апрель', t_class: 'nav-link'}, {name: 'Май', t_class: 'nav-link'}, {name: 'Июнь', t_class: 'nav-link'}, {name: 'Июль', t_class: 'nav-link'}, {name: 'Август', t_class: 'nav-link'}, {name: 'Сентябрь', t_class: 'nav-link'}, {name: 'Октябрь', t_class: 'nav-link'}, {name: 'Ноябрь', t_class: 'nav-link'}, {name: 'Декабрь', t_class: 'nav-link'} ],
      year_arr: [],
      year_tab: new Date().getFullYear(),
      mon__tab: 0,
     }
   },


   mounted() {
      if(Number(this.$route.params.orderid)>0 )
             this.order_id = Number(this.$route.params.orderid)
      this.make = Number(this.$route.params.make)
      if( Number(this.$route.params.counterpartyid)>0 ) 
           this.a_counterparty_id = Number(this.$route.params.counterpartyid)

      if(this.order_id==0)
                this.make = 0
      
      for (var i=-1; i<4; i++){
        this.year_arr.push({name: this.year_tab-i})
      }    

      this.moodle_url = MoodleApiURL

    axios
      .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, make: this.make, page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.role = this.info.role
            this.numPages = this.info.numPages
	        this.page = this.info.page
 
            if( this.role=='counterparty' )
                    this.print_v = 'false'

              console.log(response)
       })
      .catch(error => {
              console.log(error.response)
        }),

    axios
      .post(JsonApiURL+'api/status_json.php', {list: { where: "learn=1", sessionId: session_t.sessionId }})
      .then(response => { 
            this.status_array = response.data.list
       })
      .catch(error => {
              console.log(error.response)
        })

    if(this.order_id == 0) {
	    axios
                .post(JsonApiURL+'api/counterparty_json.php', {list: { sessionId: session_t.sessionId }})
    		.then(response2 => { 
        	    this.info2 = response2.data
		    //this.numPages = this.info2.numPages
		    //this.page = this.info2.page
        	    console.log(response2)
    		})
    		.catch(error => {
            	    console.log(error.response)
        	})
     }

  },


  methods: {
    search_go(clean) {
    if(clean){
        this.namesearch = ''
        this.datesearch = ''
        this.datesearch2 = ''
        this.counterpartysearch = 0
        this.status = 0
    }
    for (var i=0; i<12; i++){
        this.mon_arr[i].t_class =  'nav-link'
    }    
    /*var counterparty_id = this.counterpartysearch
    if(this.a_counterparty_id>0)
          counterparty_id = this.a_counterparty_id*/

    axios
      .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
              console.log(response)
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    page_go(page) {
    this.page = page

    axios
      .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
      //.post(JsonApiURL+'api/groups_json.php', {list: {   page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    tab_go(month) {
     if(this.year_tab>0) {    
        var date_t1 = new Date(this.year_tab, month, 1, 0, 0, 0, 0).toLocaleDateString('en-CA')
        var date_t2 = new Date(this.year_tab, month+1, 0, 0, 0, 0, 0).toLocaleDateString('en-CA')
        this.datesearch = date_t1
        this.datesearch2 = date_t2
        for (var i=0; i<12; i++){
            this.mon_arr[i].t_class =  'nav-link'
        }    
        this.mon_arr[month].t_class =  'nav-link active'


        axios
        .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
        //.post(JsonApiURL+'api/groups_json.php', {list: {date1: date_t1, date2: date_t2, course: this.namesearch,    page: this.page,  sessionId: session_t.sessionId }})
        .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
        })
        .catch(error => {
              console.log(error.response)
        })
     }    
    },

    lstream_create_set(lstream_id){
        this.modal_objectId = lstream_id
        var i = this.info.list.findIndex(item => item.lstream_id == this.modal_objectId)
        this.modal_date_begin  = this.info.list[i].date_begin
        this.modal_date_begin2 = this.info.list[i].date_begin2
        this.modal_date_end =  this.info.list[i].date_end
        this.modal_date_protocol = this.info.list[i].date_protocol
        this.date_begin = ''
        this.date_end = ''
        this.date_protocol = this.info.list[i].date_protocol
        this.modal_days =  this.info.list[i].days
    },

    lstream_create_go(){

        axios
        .post(JsonApiURL+'api/groups_json.php', {lstream_create: {objectId: this.modal_objectId, date_begin: this.date_begin, date_end: this.date_end, date_protocol: this.date_protocol,   sessionId: session_t.sessionId }})
        .then(response => { 
            this.info9 = response.data

            axios
            .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
            .then(response2 => { 
                this.info = response2.data
                this.numPages = this.info.numPages
	            this.page = this.info.page
            })
            .catch(error => {
                  console.log(error.response)
            })
        console.log(response)


        })
        .catch(error => {
              console.log(error.response)
        })
    },
    
    onChangeDateBegin(){
	  if( this.date_begin!='' ){
          if(this.date_begin < this.modal_date_begin)
                this.date_begin = this.modal_date_begin

          if(this.date_begin > this.modal_date_begin2)
                this.date_begin = this.modal_date_begin2

	      var currentDate = new Date(this.date_begin)
	      currentDate.setDate(currentDate.getDate() + this.modal_days )
	      this.date_end = currentDate.toLocaleDateString('en-CA')
	  }
     },
     
    onChangeDateEnd(){
	  if( this.date_end!='' ){
          if(this.date_end > this.modal_date_end)
                this.date_end = this.modal_date_end

          if(this.date_end < date_begin)
                this.date_end = this.date_begin
	  }
     },
     
     
    cohortDelete(groupId, name ){
	var fl = confirm('Удалить  группу: ' + name + '?');
	if(fl) {
	axios
          .post(JsonApiURL+'api/groups_json.php', {delete: {objectId: groupId}})
          .then(response => { 
            //this.info9 = response.data
         axios
           .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: 0, page: this.page, sessionId: session_t.sessionId }})
           .then(response => { 
              this.info = response.data
              this.numPages = this.info.numPages
	          this.page = this.info.page
            })
           .catch(error => {
              console.log(error.response)
            })

        })
          .catch(error => {
              console.log(error.response)
            })

       }
   },

    documentModalArg(lstream_id, name, main_teacher_id) {
        this.modal_lstream_id = lstream_id
        this.modal_name = name
        this.modal_main_teacher_id = main_teacher_id

    },



},


	template: `<div><navigation></navigation><h3>Учебные потоки</h3> 

  <h4 style="text-align: center; color: red;">{{message}}</h4>

    <table >
        <tr v-if="order_id==0"  align="left">
            <td  style="padding-left: 0px;  padding-right: 10px;" >Начало обучения c </td>
            <td  style="padding-left: 0px;  padding-right: 15px;" ><input type="date" v-model="datesearch" placeholder="Дата"  ></td>
            <td style="padding-left: 5px;  padding-right: 5px;"> по </td>
            <td  style="padding-left: 0px;  padding-right: 15px;" ><input type="date" v-model="datesearch2" placeholder="Дата"  ></td>
            <td style="padding-left: 10px;  padding-right: 5px;" >
		    <select  v-model="status"  id="input_status"  aria-label="Статус">
    		    <option value="0"> - статус - </option>
    		    <option v-for="item_status in status_array" :value="item_status.status_id">{{item_status.name}} </option>
		    </select>
	    </td>
        <td style="padding-left: 5px;  padding-right: 15px;"  v-if="order_id==0 && role!='counterparty'" ><small>
	        <select v-model="counterpartysearch">
	        <option value="0"> -  Организация  - </option>
            <option v-for="item2 in info2.list" :value="item2.counterparty_id">
	            {{item2.shortname.substring(0, 45)}} 
	        </option>
	        </select>
	    </small></td>
        </tr>
        <tr  align="left">
            <td colspan="5" style="padding-top: 20px; padding-right: 15px;"><input type="text" v-model="namesearch" placeholder="Курс"   size="70"></td>
            <td  style="padding-top: 20px; padding-left: 15px;  padding-right: 0px; text-align: right;" > <button  @click="search_go(0)">&nbsp;<i class="fa-solid fa-magnifying-glass"></i>&nbsp;Поиск&nbsp;</button>&nbsp;&nbsp;&nbsp;&nbsp;<button  title="Сбросить все фильтры"   @click="search_go(1)"  ><i class="fa-solid fa-text-slash"></i> </button> </td>
        </tr>
    </table>


    <br />
    <!--<table >
        <tr  align="left">
            <td  style="padding-left: 0px;  padding-right: 5px;" ><input type="text" v-model="namesearch" placeholder="Группа"   size="50"></td>
            <td style="padding-left: 5px;  padding-right: 5px;" >
		    <select  v-model="status"  id="input_status"  aria-label="Статус">
    		    <option value="0"> - статус - </option>
    		    <option v-for="item_status in status_array" :value="item_status.id">{{item_status.name}} </option>
		    </select>
	    </td>

            <td  style="padding-left: 15px;  padding-right: 15px;" align="left"> <button  @click="search_go(0, '')">&nbsp;<i class="fa-solid fa-magnifying-glass"></i>&nbsp;Поиск&nbsp;</button></td>
            <td  style="padding-left: 15px;  padding-right: 0px;" > <button  title="Сбросить все фильтры"   @click="search_go(1, '')"  ><i class="fa-solid fa-text-slash"></i> </button> </td>
        </tr>
    </table>-->

    <br />
    <table class="table">
      <thead>
        <tr  align="left">
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Поток</div> </th>
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Период обучения</div> </th>
          <th>  <div style="margin-right: 0px; font-size: smaller;">Курсы (состав комиссии, даты)</div> </th>
          <!--<th>  <div style="margin-right: 0px; font-size: smaller;">Организация</div></th>-->
          <th scope="col"><div align="center" style="margin-right: 0px; font-size: smaller;">Список <br />заказчиков</div>  </th>
