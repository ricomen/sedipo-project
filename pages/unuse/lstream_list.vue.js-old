                            <span v-else ><router-link  :to="{ name: 'group_scheduler', params: {groupid: item.lstream_id, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}"  title="Календарь" ><i class="fa-solid fa-calendar-day"></i></router-link><span style="color: green;">&nbsp;<i class="fa-solid fa-circle-exclamation"></i></span></span>
                </span>
               </nobr>
            </td>
            <td align="center" style="padding-top: 15px;"   >
