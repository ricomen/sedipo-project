			<tr><td colspan="2" style="text-align:center; padding-bottom:10px; padding-top:10px;"><b>Данные организации</b></td></tr>
			<tr><td width="40%" style="text-align:left">Название</td><td style="text-align:left">\${self-name} <i class="fa-solid fa-clone" @click="copyToClipboard('\${self-name}')" style="color:#158cba;"></i></td></tr>
