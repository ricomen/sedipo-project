			<tr><td width="40%" style="text-align:left">Название организации</td><td style="text-align:left">\${counterparty_name} <i class="fa-solid fa-clone" @click="copyToClipboard('\${counterparty_name}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Краткое название организации</td><td style="text-align:left">\${counterparty_shortname} <i class="fa-solid fa-clone" @click="copyToClipboard('\${counterparty_shortname}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Должность</td><td style="text-align:left">\${job_title} <i class="fa-solid fa-clone" @click="copyToClipboard('\${job_title}')" style="color:#158cba;"></i></td></tr>
