			<tr><td width="40%" style="text-align:left">Должность руководителя</td><td style="text-align:left">\${self-position_head} <i class="fa-solid fa-clone" @click="copyToClipboard('\${self-position_head}')" style="color:#158cba;"></i></td></tr>
