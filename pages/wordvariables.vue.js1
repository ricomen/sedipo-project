	<table class="table table-striped" width="100%" border="1">
	<tbody>
			<tr><td colspan="2" style="text-align:center; padding-bottom:10px; padding-top:10px;"><b>Данные курса</b></td></tr>
	    	<tr><td width="40%" style="text-align:left">Название курса</td><td style="text-align:left" v-model="textToCopy">\${name} <i class="fa-solid fa-clone" @click="copyToClipboard('\${name}')" style="color:#158cba;"></i>
			</td></tr>
            <tr><td width="40%" style="text-align:left">Краткое название курса</td><td style="text-align:left">\${shortname} <i class="fa-solid fa-clone" @click="copyToClipboard('\${shortname}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Навыки</td><td style="text-align:left">\${competence} <i class="fa-solid fa-clone" @click="copyToClipboard('\${competence}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Количество часов</td><td style="text-align:left">\${hours} <i class="fa-solid fa-clone" @click="copyToClipboard('\${hours}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Количество часов. Лекции</td><td style="text-align:left">\${hours_l} <i class="fa-solid fa-clone" @click="copyToClipboard('\${hours_l}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Количество часов. Практические занятия</td><td style="text-align:left">\${hours_p} <i class="fa-solid fa-clone" @click="copyToClipboard('\${hours_p}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Количество часов. Итоговая аттестация</td><td style="text-align:left">\${hours_c} <i class="fa-solid fa-clone" @click="copyToClipboard('\${hours_c}')" style="color:#158cba;"></i></td></tr> 
			<tr><td width="40%" style="text-align:left">Дата начала</td><td style="text-align:left">\${date_begin} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_begin}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата начала(русскими прописными буквами)</td><td style="text-align:left">\${date_begin_rus} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_begin_rus}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата начала, месяц(русскими прописными буквами)</td><td style="text-align:left">\${date_begin_rus_m} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_begin_rus_m}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата завершения</td><td style="text-align:left">\${date_end} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_end}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата завершения(русскими прописными буквами)</td><td style="text-align:left">\${date_end_rus} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_end_rus}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата завершения, месяц(русскими прописными буквами)</td><td style="text-align:left">\${date_end_rus_m} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_end_rus_m}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата протокола</td><td style="text-align:left">\${date_protocol} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_protocol}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата протокола(русскими прописными буквами)</td><td style="text-align:left">\${date_protocol_rus} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_protocol_rus}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата протокола, месяц(русскими прописными буквами)</td><td style="text-align:left">\${date_protocol_rus_m} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_protocol_rus_m}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата окончания срока действия обучения</td><td style="text-align:left">\${date_finish} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_finish}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата окончания срока действия обучения(русскими прописными буквами)</td><td style="text-align:left">\${date_finish_rus} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_finish_rus}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Дата окончания срока действия обучения. Месяц(русскими прописными буквами)</td><td style="text-align:left">\${date_finish_rus_m} <i class="fa-solid fa-clone" @click="copyToClipboard('\${date_finish_rus_m}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Квалификация</td><td style="text-align:left">\${qualification} <i class="fa-solid fa-clone" @click="copyToClipboard('\${qualification}')" style="color:#158cba;"></i></td></tr>
            <tr><td width="40%" style="text-align:left">Номер протокола</td><td style="text-align:left">\${protocol_num} <i class="fa-solid fa-clone" @click="copyToClipboard('\${protocol_num}')" style="color:#158cba;"></i></td></tr>
