			<tr><td width="40%" style="text-align:left">Фамилия</td><td style="text-align:left">\${lastname} <i class="fa-solid fa-clone" @click="copyToClipboard('\${lastname}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Имя</td><td style="text-align:left">\${firstname} <i class="fa-solid fa-clone" @click="copyToClipboard('\${firstname}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Отчество</td><td style="text-align:left">\${middlename} <i class="fa-solid fa-clone" @click="copyToClipboard('\${middlename}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Серия диплома</td><td style="text-align:left">\${diplom_series} <i class="fa-solid fa-clone" @click="copyToClipboard('\${diplom_series}')" style="color:#158cba;"></i></td></tr>
			<tr><td width="40%" style="text-align:left">Номер диплома</td><td style="text-align:left">\${diplom_number} <i class="fa-solid fa-clone" @click="copyToClipboard('\${diplom_number}')" style="color:#158cba;"></i></td></tr>
