         <tr><td width="40%" style="text-align:left">Адрес</td><td style="text-align:left">\${students-address}<i class="fa-solid fa-clone" @click="copyToClipboard('\${students-address}')" style="color:#158cba;"></i></td></tr>
         <tr><td width="40%" style="text-align:left">Серия паспорта</td><td style="text-align:left">\${students-pasport_series}<i class="fa-solid fa-clone" @click="copyToClipboard('\${students-pasport_series}')" style="color:#158cba;"></i></td></tr>
