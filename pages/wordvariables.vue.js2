        <tr><td width="40%" style="text-align:left">Дата начала(русскими прописными буквами)</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${date_begin_rus}')" >\${date_begin_rus}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${date_begin_rus}')" title="копировать" style="color:#158cba;"></i></td></tr>
