var Wordvariables = { 
	data: function () {
    return {
	info9: '',
        role: '',
		status1: '',
		textToCopy: '',
     }
   },


   mounted() {
    this.session = session_t


    },

	methods: {


	async copyToClipboard(textToCopy) {
      try {
        // Используем navigator.clipboard.writeText для записи [6]
        await navigator.clipboard.writeText(textToCopy);
        //alert('Текст скопирован: ' + textToCopy);
			// Показ уведомления
			var x = document.getElementById("toast");
			x.className = "toast show";
			
			// Исчезновение через 3 секунды
			setTimeout(function(){ x.className = x.className.replace("show", ""); }, 3000);
      } catch (err) {
        console.error('Ошибка при копировании:', err);
      }
    },
  

	copyText() {
	// Логика копирования
	navigator.clipboard.writeText("Текст для копирования");
	
	// Показ уведомления
	var x = document.getElementById("toast");
	x.className = "toast show";
	
	// Исчезновение через 3 секунды
	setTimeout(function(){ x.className = x.className.replace("show", ""); }, 3000);
	}


	},



	template: `
    <div><navigation></navigation><h3></h3>
	<div class="wrapper" >
	
	<div style="margin-bottom:30px;"><h2>Список переменных для добавления в шаблон документа MSword</h2>
	</div>
	<div style="align:left; margin-left:25px" >
	
	<div style="text-align: left" class="accordion border-bottom-0">
	<div id="toast" class="toast" style="position:sticky; top: 0; width:100%; text-align:center; z-index:999; width:100%">Скопировано</div>
	<details class="accordion-item">
    <summary class="accordion-button" style="padding-bottom: 8px; ">
        <div class="accordion-header user-select-none" style="color:#158cba; font-size:17pt;">Переменные для удостоверений, свидетельств, дипломов и приложений к ним</div>
    </summary>

	<table class="table table-striped" width="100%" border="1">
	<tbody>

    
        <tr><td colspan="3" style="text-align:center; padding-bottom:10px; padding-top:10px;"><b>Обязательные переменные</b></td></tr>

        <tr><td width="40%" style="text-align:left">Начало блока (Перед документом)</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${BLOCK}')">\${BLOCK}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${BLOCK}')" title="копировать" style="color:#158cba;"></i></td></tr>
	    <tr><td width="40%" style="text-align:left">Разрыв страницы (После \${BLOCK})</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${PAGE_BREAK}')">\${PAGE_BREAK}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${PAGE_BREAK}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Конец блока (После документа)</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${/BLOCK}')">\${/BLOCK}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${/BLOCK}')" title="копировать" style="color:#158cba;"></i></td></tr>



		<tr><td colspan="3" style="text-align:center; padding-bottom:10px; padding-top:10px;"><b>Данные курса</b></td></tr>


	    <tr><td width="40%" style="text-align:left">Название курса</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${name}')">\${name}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${name}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Краткое название курса</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${shortname}')" >\${shortname}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${shortname}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Навыки</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${competence}')" >\${competence}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${competence}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Количество часов</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${hours}')" >\${hours}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${hours}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Количество часов. Лекции</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${hours_l}')" >\${hours_l}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${hours_l}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Количество часов. Практические занятия</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${hours_p}')" >\${hours_p}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${hours_p}')" title="копировать" style="color:#158cba;"></i></td></tr>
        <tr><td width="40%" style="text-align:left">Количество часов. Итоговая аттестация</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${hours_c}')" s>\${hours_c}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${hours_c}')" title="копировать" style="color:#158cba;"></i></td></tr> 
