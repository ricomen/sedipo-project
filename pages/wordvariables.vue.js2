        <tr><td width="40%" style="text-align:left">Аккредитация</td><td style="text-align:left" title="копировать" @click="copyToClipboard('\${self-accreditation}')">\${self-accreditation}</td><td style="text-align:right; padding-right:20px;"><i class="fa-regular fa-copy" @click="copyToClipboard('\${self-accreditation}')" title="копировать" style="color:#158cba;"></i></td></tr>
		
</tbody>
</table>	
</details>





	</div>
	</div>

  <br />
  <div class="mb-2">
    <div align="right">
      <router-link :to="{name: 'template_list'}" ><button  class="btn btn-outline-primary"> Закрыть </button></router-link>
    </div>
  </div>
 </div>

	</div>`

};