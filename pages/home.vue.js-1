                                    <div class="bg-secondary p-2 text-start"><a class="fw-bold text-dark text-uppercase link-offset-2 link-offset-3-hover link-underline-dark link-underline-opacity-0 link-underline-opacity-75-hover" href="#">Важная информация по СЭД</a></div>
                                    <div class="pt-2 pb-2" v-for="news in news_CED" :key="news.b_id">
