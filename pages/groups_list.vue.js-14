	                <li  v-else-if="item.certificate1_template>0"><a :href="'d-api/documents-cert.php?template='+item.certificate1_template+'&groupid='+item.cohort_id+'&id=0'+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank"  class="nav-link" title="документ об образовании" > &nbsp;<i class="fa-regular fa-file-lines"></i>{{item.certificate1_name}} </a></li>
	                <li  v-if="item.certificate1_template>0 && item.modify_certificate1!=''"><a :href="'d-api/documents-cert.php?template='+item.certificate1_template+'&groupid='+item.cohort_id+'&id=0'+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank"  class="nav-link" title="автоматически созданный документ об образовании" > &nbsp;<i class="fa-regular fa-file"></i>&nbsp;&nbsp;автоматически созданный документ - {{item.certificate1_name}} </a></li>
                        <li><a  :href=""   target="_blank"  class="nav-link">&nbsp;<i class="fa-solid fa-upload"></i> Загрузить отредактированный документ - docx:  {{item.certificate1_name}}  <i class="fa-regular fa-circle-question" style="color:#137ea7" title="Для загрузки нескольких документов объедините их в один PDF файл"></i></a> 
                           <input v-model="upload_m1c[index]"   class="form-control"  :id="'input_upload1ce'+index" @change="handleUploadC1e(index, item.cohort_id)" type="file"  placeholder="Файл скана удостоверений"><br /><!--  :ref="el => { if (el) divs[index] = el }" -->
                        </li>
                        <li><hr /></li>

