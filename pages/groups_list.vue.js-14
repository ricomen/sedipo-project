                         <li v-if="item.modify_protocol!=''"><a :href="'/uploads/groups/protocol/'+item.modify_protocol" target="_blank"  class="nav-link">&nbsp;<i class="fa-regular fa-file-lines"></i>Протокол</a> </li>
                         <li v-if="item.protocol_html_length>0 && item.modify_protocol==''"><a :href="'d-api/protocol-saved.php?id='+item.cohort_id+'&file=Протокол-'+item.name+'-'+item.course_name.substring(0, 50)+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank" target="_blank"  class="nav-link" >&nbsp;<i class="fa-regular fa-file"></i>Протокол</a></li><!-- DEPRECATED -->
                         <li v-if="item.modify_protocol=='' && item.protocol_html_length==0"><a  :href="'d-api/documents-protocol.php?groupid='+item.cohort_id+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank"  class="nav-link">&nbsp;<i class="fa-regular fa-file-lines"></i>Протокол</a> </li>
                         <il><hr /></il>
                         <li><a  :href=""   target="_blank"  class="nav-link">&nbsp;<i class="fa-solid fa-upload"></i> Загрузить отредактированный протокол - docx <i class="fa-regular fa-circle-question" style="color:#137ea7" title="Для загрузки нескольких документов объедините их в один PDF файл"></i></a>
                            <input v-model="upload_m1p[index]"   class="form-control"  :id="'input_upload1pe'+index" @change="handleUploadP_e(index, item.cohort_id)"   type="file"  placeholder="Файл  протокола">
                         </li>
                         <il><hr /></il>

                         <li v-if="item.protocol_html_length>0 || item.upload_protocol!=''" ><a  :href="'d-api/documents-protocol.php?groupid='+item.cohort_id+'&print_v='+this.print_v+'&print_switch='+this.print_switch"   target="_blank"  class="nav-link">&nbsp;<i class="fa-regular fa-file"></i>Автоматически созданный протокол</a></li>
                         <li v-if="item.protocol_html_length>0 && item.upload_protocol!=''"><a :href="'d-api/protocol-saved.php?id='+item.cohort_id+'&file=Протокол-'+item.name+'-'+item.course_name.substring(0, 50)+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank" target="_blank"  class="nav-link" >&nbsp;<i class="fa-regular fa-file"></i>Ранее отредактированный протокол (html)</a></li><!-- DEPRECATED -->

                         <il><hr /></il>
                         <li v-if="item.upload_protocol!=''"><a :href="'/uploads/groups/protocol/'+item.upload_protocol" target="_blank"  class="nav-link">&nbsp;<i class="fa-regular fa-file-lines"></i>Скан протокола</a> </li>
                         <li><a  :href=""   target="_blank"  class="nav-link">&nbsp;<i class="fa-solid fa-upload"></i> Загрузить скан протокола - pdf <i class="fa-regular fa-circle-question" style="color:#137ea7" title="Для загрузки нескольких документов объедините их в один PDF файл"></i></a>
                            <input v-model="upload_m1p[index]"   class="form-control"  :id="'input_upload1p'+index" @change="handleUploadP1(index, item.cohort_id)"   type="file"  placeholder="Файл скана протокола"><br />
                         </li>
                         <li style="text-align: right; margin-right: 7px;">
                            <span v-if="wait"><i class="fa-solid fa-cog fa-spin"></i></span>
                            <span v-if="import_total==0"><button type="button" class="btn btn-primary" @click="uploadGoP(index, item.cohort_id)" > Загрузить </button></span>
                           <span v-else><p>Загружено: {{import_total}} записей</p></span>
                           </small>
                         </li>
                      </ul>
              </div>
            </td>
            
            <td align="center" style="padding-left: 0px; padding-right: 0px;"  width="10%" >
               <div   class="dropdown"  v-if="item.certificate1_template>0">
                <button class="btn btn-link dropdown-toggle dropdown-toggle-split" href="" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration: none;"><i class="fa-solid fa-list-check"></i>&nbsp;</button>
