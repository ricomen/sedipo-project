                </td>-->


                <td  v-if="role!='counterparty'"   style="padding-left: 5px;  padding-right: 0px;">
		            <a   @click="cohortDelete(item.cohort_id, item.name)"   title="Удалить группу" style="color: red;" ><i class="far fa-trash-alt"></i></a>
