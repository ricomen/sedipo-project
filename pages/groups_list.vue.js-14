var GroupsList = {
  data: function () {
    return {
      role: '',
      is_LMS: IS_LMS,
      is_DEVELOPMENT: IS_DEVELOPMENT,
      IS_SECR: IS_SECR,
      moodle_path: '',
      info: [],
      info2: [],
      info3: [],
      info9: [],
      order_id: 0,
      make: 0,
      //a_counterparty_id: 0,
      status: 0,
      status_array:  [], 
      message: '',
      datesearch: '',
      datesearch2: '',
      namesearch: '',
      counterpartysearch: 0,
      numPages: 0,
      page: 1,
      date_begin: 0,
      date_end: 0,
      date_protocol: 0,
      modal_objectId: 0,
      modal_date_begin: '',
      modal_date_begin2: '',
      modal_date_end: '',
      modal_date_protocol: '',
      modal_days: '',
      mon_arr: [{name: 'Январь', t_class: 'nav-link'}, {name: 'Февраль', t_class: 'nav-link'}, {name: 'Март', t_class: 'nav-link'}, {name: 'Апрель', t_class: 'nav-link'}, {name: 'Май', t_class: 'nav-link'}, {name: 'Июнь', t_class: 'nav-link'}, {name: 'Июль', t_class: 'nav-link'}, {name: 'Август', t_class: 'nav-link'}, {name: 'Сентябрь', t_class: 'nav-link'}, {name: 'Октябрь', t_class: 'nav-link'}, {name: 'Ноябрь', t_class: 'nav-link'}, {name: 'Декабрь', t_class: 'nav-link'} ],
      year_arr: [],
      year_tab: new Date().getFullYear(),
      mon_tab: 0,
      upload_index: 0,
      upload_cohort_id: 0,
      upload_m1c: [],
      uploadfile1c: '',
      file1c_name: '',
      file1c_type: '',
      upload_m2c: [],
      uploadfile2c: '',
      file2c_name: '',
      file2c_type: '',
      upload_m1p: [],
      uploadfile1p: '',
      file1p_name: '',
      file1p_type: '',
      uploadfile1pe: '',
      file1pe_name: '',
      file1pe_type: '',
      divs: [],
      is_number_saved:  true,
      print_v: 'true',
      print_switch: false,
      wait: 0,
      import_total: 0,
      helpers: {},
      normative: {},
     }
   },


   mounted() {
      if(Number(this.$route.params.orderid)>0 )
             this.order_id = Number(this.$route.params.orderid)

      this.make = Number(this.$route.params.make)
      /*if( Number(this.$route.params.counterpartyid)>0 ) 
             this.a_counterparty_id = Number(this.$route.params.counterpartyid)
      else          
             this.a_counterparty_id = 0*/

      if(this.order_id==0)
                this.make = 0
      
      for (var i=-1; i<4; i++){
        this.year_arr.push({name: this.year_tab-i})
      }    

      this.moodle_url = MoodleApiURL
      
      this.datesearch = session_var.group_datesearch
      this.datesearch2 = session_var.group_datesearch2
      this.namesearch = session_var.group_namesearch
      this.groupsearch = session_var.group_groupsearch
      this.counterpartysearch = session_var.group_counterpartysearch

    axios
      .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: this.make,  page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.role = this.info.role
            this.numPages = this.info.numPages
            this.page = this.info.page
 
           console.log(response)
       })
      .catch(error => {
              console.log(error.response)
        }),

    axios
      .post(JsonApiURL+'api/status_json.php', {list: { where: "learn=1", sessionId: session_t.sessionId }})
      .then(response => { 
            this.status_array = response.data.list
       })
      .catch(error => {
              console.log(error.response)
        })

    if(this.order_id == 0) {
	    axios
                .post(JsonApiURL+'api/counterparty_json.php', {list: { sessionId: session_t.sessionId }})
    		.then(response2 => { 
        	    this.info2 = response2.data
		    //this.numPages = this.info2.numPages
		    //this.page = this.info2.page
        	    console.log(response2)
    		})
    		.catch(error => {
            	    console.log(error.response)
        	})
     }



    axios
      .post(JsonApiURL+'api/helpers_json.php', {table: 'a_groups_list',  sessionId: session_t.sessionId })
      .then(response => {
            const data = response.data;

            if(Object.keys(data).length) {

                const values = Object.values(data);
                for (const value of values) {
                    if(value['description']) this.helpers[value['name']] = value['description'];
                    if(value['normative']) this.normative[value['name']] = value['normative'];
                }

                const labels = document.querySelectorAll('label');
                labels.forEach(label => {
                    const getFor = label.htmlFor;
                    if(getFor in this.helpers) {
                        const help_block = ` <a title='${this.helpers[getFor]}'><span class="text-primary"><i class="fa-regular fa-circle-question"></i></span></a>`;
                        label.innerHTML = label.innerHTML + (help_block);
                    }
                    if(getFor in this.normative) {
                        const help_block = ` <a title='${this.normative[getFor]}'><span class="text-primary"><i class="fa-solid fa-book"></i></span></a>`;
                        label.innerHTML = label.innerHTML + (help_block);
                    }

                })

            } else {
                console.log('NO DATA')
            }

       })
      .catch(error => {
              console.log(error.response)
      })



  },


  

  methods: {
    search_go(clean) {
    if(clean){
        this.namesearch = ''
        this.groupsearch = ''
        this.datesearch = ''
        this.datesearch2 = ''
        this.counterpartysearch = this.a_counterparty_id
        this.status = 0
    }

    session_var.group_datesearch = this.datesearch
    session_var.group_datesearch2 = this.datesearch2
    session_var.group_namesearch = this.namesearch 
    session_var.group_groupsearch = this.groupsearch 
    session_var.group_counterpartysearch = this.counterpartysearch

    for (var i=0; i<12; i++){
        this.mon_arr[i].t_class =  'nav-link'
    }    
    /*var counterparty_id = this.counterpartysearch
    if(this.a_counterparty_id>0)
          counterparty_id = this.a_counterparty_id*/

    axios
      .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, group: this.groupsearch, status: this.status,  counterparty_id: this.counterpartysearch,   page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
              console.log(response)
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    page_go(page) {
    this.page = page

    axios
      .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,   page: this.page,  sessionId: session_t.sessionId }})
      //.post(JsonApiURL+'api/groups_json.php', {list: {   page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    tab_go(month) {
     if(this.year_tab>0) {    
        var date_t1 = new Date(this.year_tab, month, 1, 0, 0, 0, 0).toLocaleDateString('en-CA')
        var date_t2 = new Date(this.year_tab, month+1, 0, 0, 0, 0, 0).toLocaleDateString('en-CA')
        this.datesearch = date_t1
        this.datesearch2 = date_t2
        for (var i=0; i<12; i++){
            this.mon_arr[i].t_class =  'nav-link'
        }    
        this.mon_arr[month].t_class =  'nav-link active'

    session_var.group_datesearch = this.datesearch
    session_var.group_datesearch2 = this.datesearch2
    session_var.group_namesearch = this.namesearch 
    session_var.group_groupsearch = this.groupsearch 
    session_var.group_counterpartysearch = this.counterpartysearch


        axios
        .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, group: this.groupsearch, status: this.status,  counterparty_id: this.counterpartysearch, a_counterparty_id: this.a_counterparty_id,  page: this.page,  sessionId: session_t.sessionId }})
        //.post(JsonApiURL+'api/groups_json.php', {list: {date1: date_t1, date2: date_t2, course: this.namesearch,    page: this.page,  sessionId: session_t.sessionId }})
        .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
        })
        .catch(error => {
              console.log(error.response)
        })
     }    
    },

    lstream_create_set(cohort_id){
        this.modal_objectId = cohort_id
        var i = this.info.list.findIndex(item => item.cohort_id == this.modal_objectId)
        this.modal_date_begin  = this.info.list[i].date_begin
        this.modal_date_begin2 = this.info.list[i].date_begin2
        this.modal_date_end =  this.info.list[i].date_end
        this.modal_date_protocol = this.info.list[i].date_protocol
        this.date_begin = ''
        this.date_end = ''
        this.date_protocol = this.info.list[i].date_protocol
        this.modal_days =  this.info.list[i].days
    },

    lstream_create_go(){

        axios
        .post(JsonApiURL+'api/groups_json.php', {lstream_create: {objectId: this.modal_objectId, date_begin: this.date_begin, date_end: this.date_end, date_protocol: this.date_protocol,   sessionId: session_t.sessionId }})
        .then(response => { 
            this.info9 = response.data

            axios
            .post(JsonApiURL+'api/groups_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch, a_counterparty_id: this.a_counterparty_id,  page: this.page,  sessionId: session_t.sessionId }})
            .then(response2 => { 
                this.info = response2.data
                this.numPages = this.info.numPages
	            this.page = this.info.page
            })
            .catch(error => {
                  console.log(error.response)
            })
        console.log(response)


        })
        .catch(error => {
              console.log(error.response)
        })
    },
    
    onChangeDateBegin(){
	  if( this.date_begin!='' ){
          if(this.date_begin < this.modal_date_begin)
                this.date_begin = this.modal_date_begin

          if(this.date_begin > this.modal_date_begin2)
                this.date_begin = this.modal_date_begin2

	      var currentDate = new Date(this.date_begin)
	      currentDate.setDate(currentDate.getDate() + this.modal_days )
	      this.date_end = currentDate.toLocaleDateString('en-CA')
	  }
     },
     
    onChangeDateEnd(){
	  if( this.date_end!='' ){
          if(this.date_end > this.modal_date_end)
                this.date_end = this.modal_date_end

          if(this.date_end < date_begin)
                this.date_end = this.date_begin
	  }
     },
     
     
    cohortDelete(groupId, name ){
	var fl = confirm('Удалить  группу: ' + name + '?');
	if(fl) {
	axios
          .post(JsonApiURL+'api/groups_json.php', {delete: {objectId: groupId}})
          .then(response => { 
            //this.info9 = response.data
         axios
           .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: 0, page: this.page, sessionId: session_t.sessionId }})
           .then(response => { 
              this.info = response.data
              this.numPages = this.info.numPages
	          this.page = this.info.page
            })
           .catch(error => {
              console.log(error.response)
            })

        })
          .catch(error => {
              console.log(error.response)
            })

       }
   },

    lstream_unlink(cohort_id, name ){
	var fl = confirm('Убрать группу:' + name + ' из  учебого потока ?');
	if(fl) {
	axios
          .post(JsonApiURL+'api/lstream_json.php', {lstream_unlink: { cohort_id: cohort_id}})
          .then(response => { 
            this.info9 = response.data
            axios
           .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: 0, page: this.page, sessionId: session_t.sessionId }})
            .then(response => { 
              this.info = response.data
              this.numPages = this.info.numPages
	          this.page = this.info.page
             })
            .catch(error => {
              console.log(error.response)
             })

           })
          .catch(error => {
              console.log(error.response)
            })

       }
    },



     uploadGoC(index, cohortId) {
        this.wait = 1
        if( this.upload_cohort_id==cohortId  && cohortId>0 ){
          if(this.file1ce_type == 'application/pdf' || this.file1ce_type == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' || this.file1ce_type == 'image/png'){
                const formData = new FormData();
                formData.append('upload1ce', this.uploadfile1ce)
                formData.append('file1ce_name', this.file1ce_name)
                formData.append('cohort_id', cohortId)
                formData.append('sessionId', session_t.sessionId)

                axios
                    .post(JsonApiURL+'api/groups_upload_json.php', formData, {headers: {'Content-Type': 'multipart/form-data'}})
                    .then(response => {
                      this.info9 = response.data
                      this.wait = 0;

                      axios
                       .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: 0, a_counterparty_id: this.a_counterparty_id,  page: this.page,  sessionId: session_t.sessionId }})
                       .then(response => { 
                           this.info = response.data
                           this.numPages = this.info.numPages
                           this.page = this.info.page
                           this.upload_cohort_id = 0
                           console.log(response)
                       })
                       .catch(error => {
                            console.log(error.response)
                       })

                      console.log(response)
                })
                .catch(error => {
                    console.log(error.response)
                })
          } 

          if( this.file2ce_type == 'application/pdf' || this.file2ce_type == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' || this.file2ce_type == 'image/png' ){
                const formData = new FormData();
                formData.append('upload2ce', this.uploadfile2ce)
                formData.append('file2ce_name', this.file2ce_name)
                formData.append('cohort_id', cohortId)
