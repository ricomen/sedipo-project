     },



    printChanged(){
     axios
      .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: this.make,  page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
            this.page = this.info.page

           console.log(response)
       })
      .catch(error => {
              console.log(error.response)
        })
    }

},


	template: `<div><navigation></navigation><h3>Учебные группы</h3> 

  <h4 style="text-align: center; color: red;">{{message}}</h4>

    <!--<h4 v-if="role!='counterparty' && a_counterparty_id>0"  style="text-align: right;" > {{info.counterparty_title_shortname}} </h4>-->
    <!--<div   class="mb-3 row"><label for="upload_scan_docs"  class="form-label col-sm-3"   >Категория </label></div>-->
    <table >
        <tr v-if="order_id==0"  align="left">
            <td  colspan="4"  style="padding-left: 0px;  padding-right: 10px;" >Начало обучения c <input type="date" v-model="datesearch" placeholder="Дата"  >  по <input type="date" v-model="datesearch2" placeholder="Дата"  ></td>
            <td style="padding-left: 10px;  padding-right: 5px;" >
		    <select  v-model="status"  id="input_status"  aria-label="Статус">
    		    <option value="0"> - статус - </option>
    		    <option v-for="item_status in status_array" :value="item_status.status_id">{{item_status.name}} </option>
		    </select>
	    </td>
        <td style="padding-left: 5px;  padding-right: 15px;"  v-if="order_id==0 && role!='counterparty' " ><small>
	        <select v-model="counterpartysearch">
	        <option value="0"> -  Организация  - </option>
            <option v-for="item2 in info2.list" :value="item2.counterparty_id">
	            {{item2.shortname.substring(0, 45)}} 
	        </option>
	        </select>
	    </small></td>
        </tr>
        <tr  align="left">
            <td colspan="5" style="padding-top: 20px; padding-right: 15px;"><input type="text" v-model="namesearch" placeholder="Курс"   size="70"   @keyup.enter="search_go(0)"></td>
            <td  style="padding-top: 20px; padding-left: 15px;  padding-right: 0px; text-align: right;" > <button  @click="search_go(0)">&nbsp;<i class="fa-solid fa-magnifying-glass"></i>&nbsp;Поиск&nbsp;</button>&nbsp;&nbsp;&nbsp;&nbsp;<button  title="Сбросить все фильтры"   @click="search_go(1)"  >&nbsp;<i class="fa-solid fa-xmark"></i>&nbsp;Сбросить фильтры&nbsp;</button> </td>
        </tr>
        <tr  align="left">
            <td  style="padding-top: 10px; padding-left: 0px;  padding-right: 5px;" ><input type="text" v-model="groupsearch" placeholder="Группа"   size="50"   @keyup.enter="search_go(0)"></td>
        </tr>
    </table>


    <br />
    <table class="table">
      <thead>
        <tr  align="left">
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Учебная группа</div> </th>
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Период обучения</div> </th>
          <th>  <div style="margin-right: 0px; font-size: smaller;">Курсы</div> </th>
          <th>  <div style="margin-right: 0px; font-size: smaller;">Организация</div></th>
          <th scope="col"><div align="center" style="margin-right: 0px; font-size: smaller;">Протокол</div>  </th>
          <th scope="col"><div align="center" style="margin-right: 0px; font-size: smaller;">Документы  </th>
          <th scope="col" width="5%"><div v-if="this.is_LMS>0" align="center" style="margin-right: 0px; font-size: smaller;"></th>

        </tr>
      </thead>
     <tbody>   
        <tr v-for="(item, index) in info.list"  align="left" >  
            <td style="padding-left: 0px; padding-right: 10px;" >
                <!--<table border="0"><tr><td valign="middle" style="padding-left: 0px; padding-right: 7px;" ><nobr>{{item.name}}&nbsp;({{item.count}})<i></nobr></td> </tr></table>-->
                <nobr>{{item.name}}&nbsp;&nbsp;<i style="color: #555;">({{item.count}} чел.)</i></nobr>
            </td>
            <td  style="padding-left: 10px; padding-right: 10px;"  >
                <span v-if="item.date_begin!=''"><small>{{new Date(item.date_begin).toLocaleDateString("ru")}} <!--<br /><small>-</small>--> <br />{{new Date(item.date_end).toLocaleDateString("ru")}}</small></span>
            </td>
            <td  style="padding-left: 10px; padding-right: 10px;"  >{{item.course_name}} 
               <nobr>
                <!--<router-link  :to="{ name: 'group_edit', params: {groupid: item.cohort_id, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}" title="Редактировать настройки" ><i class="fa-solid fa-pencil"></i></router-link>-->
                <span v-if="item.consulting==0">
                    <!--<span v-if="item.scheduler_count==0" ><router-link  :to="{ name: 'group_scheduler', params: {groupid: item.cohort_id, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}"  title="Календарь" ><i class="fa-solid fa-calendar-day"></i></router-link><span style="color: red;">&nbsp;<i class="fa-solid fa-circle-exclamation"></i></span></span>-->
                    <span v-if="item.date_begin==''" ><router-link  :to="{ name: 'group_scheduler', params: {groupid: item.cohort_id, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}"  title="Календарь" ><i class="fa-solid fa-calendar-day"></i></router-link><span style="color: red;">&nbsp;<i class="fa-solid fa-circle-exclamation"></i></span></span>
                    <span v-else>
                        <a @click="lstream_unlink(item.cohort_id, item.name )" style="color: red;" title="Убрать группу из учебного потока"><i class="fa-solid fa-thumbtack-slash"></i></a>
                        &nbsp;&nbsp;<router-link v-if="item.status_id<12"  :to="{ name: 'group_scheduler', params: {groupid: item.cohort_id, orderid: this.order_id, counterpartyid: this.a_counterparty_id}}"  title="Календарь" ><i class="fa-solid fa-calendar-day"></i></router-link>
                    </span>
                </span>
               </nobr>
            </td>
            <td  style="padding-left: 10px; padding-right: 5px;"  ><small>{{item.counterparty_shortname}}</small>
            </td>
            <td align="center" style="padding-top: 7px;"   >
              <div v-if="(role!='counterparty' || item.status_id>=10) && item.protocol_template>0"   class="btn-group"  style="padding-top: 1px;">
                <button class="btn btn-link dropdown-toggle dropdown-toggle-split" href="" role="button" id="dropdownProtocolMenuLink" data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration: none;"><i class="fa-solid fa-file-lines"></i>&nbsp;</button>
                    <!--<a v-if="item.upload_protocol!=''" :href="'/uploads/groups/protocol/'+item.upload_protocol" target="_blank"  type="button" class="btn btn-outline-primary  btn-sm" > <i class="fa-solid fa-file-lines"></i> </a>
                    <a v-else-if="item.protocol_html_length==0"  :href="'d-api/documents-protocol.php?groupid='+item.cohort_id+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank" type="button" class="btn btn-outline-primary  btn-sm" > <i class="fa-solid fa-file-lines"></i> </a>
                    <a v-else :href="'d-api/protocol-saved.php?id='+item.cohort_id+'&file=Протокол-'+item.name+'-'+item.course_name.substring(0, 50)+'&print_v='+this.print_v+'&print_switch='+this.print_switch" target="_blank" target="_blank" type="button" class="btn btn-outline-primary  btn-sm" > <i class="fa-solid fa-file-lines"></i> </a>
                    <button type="button" class="btn btn-outline-primary  btn-sm dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false"></button>-->

