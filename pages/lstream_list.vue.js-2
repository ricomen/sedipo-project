                            &nbsp;&nbsp;{{item2.order_name}}</button>&nbsp;&nbsp;&nbsp;&nbsp;<a @click="lstream_unlink(item.lstream_id, item2.cohort_id, item2.shortname )" style="color: red;" title="Убрать из этого учебного потока"><i class="fa-solid fa-thumbtack-slash"></i></a></small>
