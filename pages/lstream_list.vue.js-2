var LstreamList = {
  data: function () {
    return {
      role: '',
      moodle_path: '',
      info: [],
      info2: [],
      info3: [],
      info4: [],
      info5: [],
      info9: [],
      order_id: 0,
      make: 0,
      a_lstream_id: 0,
      status: 0,
      status_array:  [], 
      message: '',
      datesearch: '',
      datesearch2: '',
      namesearch: '',
      lstreamsearch: '',
      counterpartysearch: 0,
      numPages: 0,
      page: 1,
      date_begin: 0,
      date_end: 0,
      date_protocol: 0,
      wait: 0,
      modal_lstream_id: 0,
      modal_objectId: 0,
      modal_date_begin: '',
      modal_date_begin2: '',
      modal_date_end: '',
      modal_date_protocol: '',
      modal_days: '',
      modal_item: [],
      modal_counterparty_list: [],
      modal_teacher_id: 0,
      modal_snils_check_sum: true,
      modal_cohort_id: 0,
      users_list: [],
      modal_counterparty_id: 0,
      modal_order_id: 0,

      modal_name: '',
      modal_main_teacher_id: 0,

      print_v: 'true',
      mon_arr: [{name: 'Январь', t_class: 'nav-link'}, {name: 'Февраль', t_class: 'nav-link'}, {name: 'Март', t_class: 'nav-link'}, {name: 'Апрель', t_class: 'nav-link'}, {name: 'Май', t_class: 'nav-link'}, {name: 'Июнь', t_class: 'nav-link'}, {name: 'Июль', t_class: 'nav-link'}, {name: 'Август', t_class: 'nav-link'}, {name: 'Сентябрь', t_class: 'nav-link'}, {name: 'Октябрь', t_class: 'nav-link'}, {name: 'Ноябрь', t_class: 'nav-link'}, {name: 'Декабрь', t_class: 'nav-link'} ],
      year_arr: [],
      year_tab: new Date().getFullYear(),
      mon__tab: 0,
      importfile1: '',
      importfile1_filename: '',
      importfile1_file_type: '',
      import_total: 0,
      list_0_course_name: '',
