                   </div>


                   <div  style="padding-top: 2px; padding-left: 15px;" class="dropdown">
                     <i class="fa-regular fa-file-lines"></i> <small>Ведомость</small> <button class="btn btn-link btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"> <i class="fa-solid fa-folder-tree"></i> </button><small> <span class="normative" data-attribute="vedomost" @click.prevent="showHelper"></span></small>
                     <ul class="dropdown-menu"  style="--bs-dropdown-min-width: 25rem;">
                        <li  v-for="item2 in modal_counterparty_list" style="padding-left: 10px;" ><small>
                           <span><a :href="'d-api/documents-protocol.php?groupid='+item2.cohort_id+'&add_template=20&print_v='+this.print_v" target="_blank"  class="nav-link" title="Ведомость" > &nbsp;<span class="icon"> <i class="fa-regular fa-file-lines"></i></span> {{item2.shortname}} </a></span>
                        </li>
                     </ul>
                   </div>

                   <div  style="padding-top: 2px; padding-left: 15px;" class="dropdown">
                     <i class="fa-regular fa-file-lines"></i> <small>Удостоверения</small> <button class="btn btn-link btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"> <i class="fa-solid fa-folder-tree"></i> </button><small> <span class="normative" data-attribute="certificate" @click.prevent="showHelper"></span></small>
                     <ul class="dropdown-menu"  style="--bs-dropdown-min-width: 45rem;">
                        <li  v-for="item2 in modal_counterparty_list" style="padding-left: 10px;" ><small>
                            <span  v-if="modal_item.certificate1_template>0 && item2.upload_certificate1==''"><a :href="'d-api/documents-cert.php?template='+modal_item.certificate1_template+'&groupid='+item2.cohort_id+'&id=0'+'&print_v='+this.print_v" target="_blank"  class="nav-link" title="документ об обраовании" > &nbsp; <i class="fa-regular fa-file-lines"></i> {{item2.shortname}} - {{modal_item.certificate1_name}} </a></span>
                            <span  v-if="modal_item.certificate2_template>0 && item2.upload_certificate2==''"><a :href="'d-api/documents-cert.php?template='+modal_item.certificate2_template+'&groupid='+item2.cohort_id+'&id=0'+'&print_v='+this.print_v" target="_blank"  class="nav-link" title="документ об обраовании" > &nbsp; <i class="fa-regular fa-file-lines"></i> {{item2.shortname}} - {{modal_item.certificate2_name}} </a></span>
                            <span  v-if="item2.certificate1_template>0 && item2.upload_certificate1!=''"><a :href="'uploads/groups/certificate/'+item.upload_certificate1" target="_blank"  class="nav-link" title="Скан документа об обраовании" > &nbsp;<i class="fa-regular fa-file-lines"></i> {{item2.shortname}} - {{modal_item.certificate1_name}} </a></span>
                            <span  v-if="item2.certificate2_template>0 && item2.upload_certificate2!=''"><a :href="'uploads/groups/certificate/'+item.upload_certificate2" target="_blank"  class="nav-link" title="Скан документа об обраовании" > &nbsp;<i class="fa-regular fa-file-lines"></i> {{item2.shortname}} - {{modal_item.certificate2_name}} </a></span>
                     </ul>
                   </div>

                   <div  style="padding-top: 2px; padding-left: 15px;" class="dropdown">
                     <i class="fa-regular fa-file-lines"></i> <small>Протоколы</small> <button class="btn btn-link btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"> <i class="fa-solid fa-folder-tree"></i> </button><small> <span class="normative" data-attribute="protocol" @click.prevent="showHelper"></span></small>
                     <ul class="dropdown-menu"  style="--bs-dropdown-min-width: 25rem;">
                        <li  v-for="item2 in modal_counterparty_list" style="padding-left: 10px;" ><small>
                            <span  v-if="item2.upload_protocol!=''""><a :href="'uploads/groups/protocol/'+item2.upload_protocol" target="_blank"  class="nav-link" title="Скан протокола" >{{item2.shortname}}</a></span>
                            <span  v-else-if="item2.protocol_html_length>0"><a :href="'d-api/protocol-saved.php?id='+item2.cohort_id+'&print_v='+this.print_v" target="_blank"  class="nav-link" title="Протокол"  >{{item2.shortname}}</a>  </span>
                            <span  v-else ><a :href="'d-api/documents-protocol.php?groupid='+item2.cohort_id+'&id=0&print_v='+this.print_v"  target="_blank"  class="nav-link" title="Протокол" >{{item2.shortname}}</a></span>
                        </small></li>
                   </div>

                   <div  style="padding-top: 2px; padding-left: 15px;" class="dropdown">
                     <i class="fa-regular fa-file-lines"></i> <small>Заявление / Согласие на обработку персональных данных</small> <button class="btn btn-link btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"> <i class="fa-solid fa-folder-tree"></i> </button><small> <span class="normative" data-attribute="agreement" @click.prevent="showHelper"></span></small>
                     <ul class="dropdown-menu"  style="--bs-dropdown-min-width: 25rem;">
                        <li  v-for="item2 in modal_counterparty_list" style="padding-left: 10px;"><small>
                          <span  v-if="item2.additions_list[3].upload_file == ''" ><small><a :href="'d-api/documents-order.php?contract_id='+item2.contract_id+'&addition=0&id='+item2.order_id+'&print_v='+this.print_v"  target="_blank"  class="nav-link" title="Заявление / Согласие на обработку персональных данных" >{{item2.shortname}}</a></small></span>
                          <span  v-if="item2.additions_list[3].upload_file != ''" ><small><a :href="item2.additions_list[3].upload_dir+item2.additions_list[3].upload_file"  target="_blank" class="nav-link"  title="Заявление / Согласие на обработку персональных данных" >{{item2.shortname}}&nbsp<span style="color: green;">&nbsp<i class="fa-solid fa-check"></i></span></a></small></span>
                        </li>
                     </ul>
                   </div>
                   <div  style="padding-top: 2px; padding-left: 15px;" class="dropdown">
                     <i class="fa-regular fa-file-lines"></i> <small><span v-if="modal_teacher_id>0"><a :href="'d-api/files_teacher.php?teacher_id='+modal_teacher_id" target="_blank"  class="nav-link" title="Договор с преподавателем"> Договор с преподавателем </a></span><span v-else>Договор с преподавателем (преподаватель не назначен)</span>  <span class="normative" data-attribute="teacher_contract" @click.prevent="showHelper"></small></span>
                   </div>
                </div>

                <div  class="col-md" style="text-align: left;">
                     <p v-if="modal_item.type_of_education_id==1 || (modal_item.type_of_education_id==2 && modal_item.subtype_of_education_id!=3 )" style="margin-bottom: 7px; margin-top: 7px;" >
                          <nobr><a :href="'reports/frdo.php?t='+modal_item.type_of_education_id+'&id='+this.modal_lstream_id"  target="_blank"  class="nav-link" >&nbsp;<i class="fa-regular fa-file-excel"></i></span><small>ФИС ФРДО</small>
                           <button v-if="!modal_snils_check_sum" style="color: red;" title="Некорректный СНИЛС обучающегося" class="btn btn_link"  data-bs-dismiss="modal" @click.prevent="closeHelperMascot"  ><i class="fa-solid fa-circle-exclamation"></i></button>
                          <small><span class="normative" data-attribute="fis_frdo" @click.prevent="showHelper"></span></small></a></nobr>
                     </p>

                     <p v-if="modal_item.type_of_education_id==1 || (modal_item.type_of_education_id==2 && modal_item.subtype_of_education_id!=3 )" style="margin-bottom: 7px; margin-top: 7px;" ><a :href="'reports/ercdo.php?t='+modal_item.type_of_education_id+'&id='+this.modal_lstream_id"  target="_blank"  class="nav-link" ><nobr> &nbsp;<i class="fa-regular fa-file-excel"></i></span> <small>ЕР ЦДО</small></nobr> <span class="normative" data-attribute="ercdo" @click.prevent="showHelper"></span></a></p>

                     <p v-if="modal_item.type_of_education_id==3 || modal_item.subtype_of_education_id==3 "  style="margin-bottom: 7px; margin-top: 7px;" ><a :href="'reports/eisot.php?id='+this.modal_lstream_id"  target="_blank" class="nav-link" > &nbsp;<i class="fa-regular fa-file-excel"></i></span> <small>Выгрузка в ЕИСОТ</small> </a>
                        &nbsp;&nbsp;<small><label for="input_calendar1"  class="form-label "   ><b>Импорт номеров удостоверений из ЕИСОТ<b/></label>
                        <input name="importfile1"  class="form-control" id="input_eisot"    type="file"     @change="handleEisotUpload()" >
                        <span v-if="wait"><i class="fa-solid fa-cog fa-spin"></i></span>
                        <span v-if="import_total==0"><button type="button" class="btn btn-primary" @click="eisotSave()" > Загрузить </button></span>
                        <span v-else><p>Загружено: {{import_total}} записей</p></span>
                        </small>
                      </p>
                 </div>
        </div>

<div>
<br /><b>Дополнительные документы</b><br />

<div class="row">
<label for="input_add"  class="form-label col-2" >Новый документ</label>
                        <div class="col"><input name="importfile1"  class="form-control " id="input_add"    type="file"     @change="handleAddUpload()" >    <span v-if="wait"><i class="fa-solid fa-cog fa-spin"></i></span></div>
                        <div class="col-2"><span v-if="import_total==0"><button type="button" class="btn btn-outline-primary" @click="addSave()" > Загрузить </button></span>  <span v-else><p>Загружено</p></span></div>
</div>

</div>


        </div>
            <div class="modal-footer">
            <div class="row" v-if="role!='counterparty'"  style="text-align: right">
              <div class="col-md-10" style="text-align: right; padding-top: 5px;"><small><nobr>
                <input v-model="print_v" type="radio" value="false" class="form-check-input" id="print_Check0" > <label class="form-check-label" for="print_Check0">  скан-копия </label>&nbsp;&nbsp;&nbsp;&nbsp; 
                <input v-model="print_v" type="radio" value="true"  class="form-check-input" id="print_Check1" > <label class="form-check-label" for="print_Check1"> версия для печати </label>&nbsp;&nbsp;&nbsp;&nbsp;
                <input v-model="print_v" type="radio" value="edit"  class="form-check-input" id="print_Check3"> <label class="form-check-label" for="print_Check3"> редактор</label>
              </nobr></small></div>
          </div>
          </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" @click="closeHelperMascot"> Закрыть </button>
      </div>






<!-- MASCOT -->
                   <div style="position: fixed; bottom: 60%;">
                   <div ref="mascot" class="mascot" :style="{left: helperMascotLeft +'px'}">
                     <div class="helperMascot__block text-end" v-show="showHelperMascot">
                        <div ref="mascotClose" id="mascot-close-container" @click="closeHelperMascot">
                            <div id="mascot-close">x</div>
                        </div>
                        <div ref="messageBox" id="helperMascot-message-box">
                            <div class="helperMascot-message-text-box">
                            </div>
                        </div>
                      </div>
                      <div  ref="helperMascot" id="helperMascot" v-show="showHelperMascot">
                        <img id="helperMascot-img" src="https://center.sedipo.ru/mascot/Polina.png" />
                      </div>
                    </div>
                    </div>


    </div>
  </div>
</div>






<!-- Modal -->
<div class="modal fade modal-xl" id="listModal" tabindex="-1" aria-labelledby="listModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="exampleModalLabel">Список слушателей по заявке</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" align="left">

  <div   v-for="(item3, index3) in users_list" style="padding-left: 10px; font-size: small;" class="row">
   <div class="col">
       {{item3.lastname}} {{item3.firstname}} {{item3.middlename}}
   </div>
   <div class="col-4">
      {{item3.job_title}}
  </div>
   <div class="col-1"><nobr>
       <router-link   v-if="item3.userId>1"  :to="{ name: 'student_edit', params: { userid: item3.userId, counterpartyid: this.modal_counterparty_id, orderid: this.modal_order_id }}"   title="Редактировать учетную запись"  ><buton data-bs-dismiss="modal"><i class="fa-solid fa-user-pen"></i></buton></router-link >
       <span v-if="!item3.snils_check_sum" style="color: red;" title="Некорректный СНИЛС" ><i class="fa-solid fa-circle-exclamation"></i></span>
  </nobr></div>

        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"> Закрыть </button>
      </div>
    </div>
  </div>
</div>



<span v-if="a_lstream_id>0" >
  <br />
  <div class="mb-2">
    <div align="right">
      <router-link :to="{ name: 'calendar' }"  ><button  class="btn btn-outline-primary"> Расписание </button></router-link>
    </div>
  </div>
 </div>
</span>


<div class="row">
<div class="col"> </div>
<div  v-if="numPages>1" aria-label="Page navigation" class="btn-toolbar col"  aria-label="pages"   style="text-align: center;">
  <ul class="pagination" >

    <li v-if="page>1" class="page-item">
      <button  @click="page_go(this.page-1)"  class="page-link" aria-label="Previous"> <span aria-hidden="true"><i class="fa-solid fa-caret-left"></i></span> </button>
    </li>
    <li v-if="page>1"class="page-item"><button @click="page_go(1)"  class="page-link" >1</button></li>
    <li v-if="page>2" class="page-item"><button   class="page-link" >...</button></li>
    <li v-if="page-2>2"class="page-item"><button @click="page_go(this.page-2)"  class="page-link" >{{page-2}}</button></li>
    <li v-if="page-1>2"class="page-item"><button @click="page_go(this.page-1)"  class="page-link" >{{page-1}}</button></li>
    <li class="page-item active" aria-current="page"><button   class="page-link">{{page}}</button></li>
    <li v-if="page+1<numPages"class="page-item"><button @click="page_go(this.page+1)"  class="page-link" >{{page+1}}</button></li>
    <li v-if="page+2<numPages"  class="page-item"><button @click="page_go(this.page+2)"  class="page-link" >{{page+2}}</button></li>
    <li v-if="page+3<numPages" class="page-item"><button   class="page-link" >...</button></li>
    <li v-if="page<numPages" class="page-item"><button @click="page_go(this.numPages)"  class="page-link" >{{numPages}}</button></li>
    <li v-if="page<numPages" class="page-item">
      <button  @click="page_go(this.page+1)"  class="page-link"  aria-label="Next">  <span aria-hidden="true"><i class="fa-solid fa-caret-right"></i></span>  </button>
    </li>
  </ul>
</div>
<div class="col-2"> </div>
</div>


<div class="row">
<small class="col-1" >
		    <select  v-model="year_tab"  id="input_status" class="form-select form-select-sm"  aria-label="Статус"  >
    		    <option value="0"> - год - </option>
    		    <option v-for="item in year_arr" :value="item.name">{{item.name}}&nbsp; </option>
		</select>
</small>    
<small class="col"><ul class="nav nav-tabs" >
    <li v-for="(item, index) in mon_arr"  class="nav-item">
        <a :class="item.t_class" @click="tab_go(index)">{{item.name}}</a>
    </li>
    </ul></small>
</div>

	</div>`

};




