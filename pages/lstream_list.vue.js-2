     }
   },

   created() {
     window.addEventListener("resize", this.mascotChangePosition);
   },
   destroyed() {
     window.removeEventListener("resize", this.mascotChangePosition);
   },

   mounted() {
      if(Number(this.$route.params.orderid)>0 )
             this.order_id = Number(this.$route.params.orderid)
      this.make = Number(this.$route.params.make)

      if( Number(this.$route.params.lstreamid)>0 ){ 
           this.a_lstream_id = Number(this.$route.params.lstreamid)
           this.order_id = -1
      }

      if(this.order_id==0)
                this.make = 0
      
      for (var i=-1; i<4; i++){
        this.year_arr.push({name: this.year_tab-i})
      }    

      this.moodle_url = MoodleApiURL
      
      
      this.datesearch = session_var.lstream_datesearch
      this.datesearch2 = session_var.lstream_datesearch2
      this.namesearch = session_var.lstream_namesearch
      this.lstreamsearch = session_var.lstream_lstreamsearch
      this.counterpartysearch = session_var.lstream_counterpartysearch
      

    axios
      .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, lstream_id: this.a_lstream_id,  page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.role = this.info.role
            this.numPages = this.info.numPages
	        this.page = this.info.page

            this.list_0_course_name = this.info.list[0].course_name
 
            if( this.role=='counterparty' )
                    this.print_v = 'false'

              console.log(response)
       })
      .catch(error => {
              console.log(error.response)
        }),

    axios
      .post(JsonApiURL+'api/status_json.php', {list: { where: "learn=1", sessionId: session_t.sessionId }})
      .then(response => { 
            this.status_array = response.data.list
       })
      .catch(error => {
              console.log(error.response)
        })

    if(this.order_id == 0) {
	    axios
                .post(JsonApiURL+'api/counterparty_json.php', {list: { sessionId: session_t.sessionId }})
    		.then(response2 => { 
        	    this.info2 = response2.data
		    //this.numPages = this.info2.numPages
		    //this.page = this.info2.page
        	    console.log(response2)
    		})
    		.catch(error => {
            	    console.log(error.response)
        	})
     }

     axios
      .post(JsonApiURL+'api/helpers_json.php', {table: this.helperTable})
      .then(response => {
            const data = response.data;
            console.log(data);

            if(Object.keys(data).length) {

                const values = Object.values(data);
                for (const value of values) {
                    //console.log(value);
                    if(value['description']) this.helpers[value['name']] = value['description'];
                    if(value['normative']) this.normative[value['name']] = value['normative'];
                }

            } else {
                console.log('NO DATA')
            }

       })
      .catch(error => {
              console.log(error.response)
      }),

    this.$refs.bsmodal.addEventListener('shown.bs.modal', event => { // при открытии модального окна
        this.clearHelpers();
        this.displayHelpers();
//         let mascotBlock  = this.$refs.mascot;
//         mascotBlock.style.opacity = "0";

    })


  },


  methods: {
    search_go(clean) {
    if(clean){
        this.namesearch = ''
        this.lstreamsearch = ''
        this.datesearch = ''
        this.datesearch2 = ''
        this.counterpartysearch = 0
        this.status = 0
    }
    for (var i=0; i<12; i++){
        this.mon_arr[i].t_class =  'nav-link'
    }    
    /*var counterparty_id = this.counterpartysearch
    if(this.a_counterparty_id>0)
          counterparty_id = this.a_counterparty_id*/

      session_var.lstream_datesearch = this.datesearch
      session_var.lstream_datesearch2 = this.datesearch2
      session_var.lstream_namesearch = this.namesearch
      session_var.lstream_lstreamsearch = this.lstreamsearch
      session_var.lstream_counterpartysearch = this.counterpartysearch
      


    axios
      .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, lstream: this.lstreamsearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
              console.log(response)
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    page_go(page) {
    this.page = page

    axios
      .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, lstream: this.lstreamsearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
      //.post(JsonApiURL+'api/groups_json.php', {list: {   page: this.page,  sessionId: session_t.sessionId }})
      .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
       })
      .catch(error => {
              console.log(error.response)
      })
    },

    tab_go(month) {
     if(this.year_tab>0) {    
        var date_t1 = new Date(this.year_tab, month, 1, 0, 0, 0, 0).toLocaleDateString('en-CA')
        var date_t2 = new Date(this.year_tab, month+1, 0, 0, 0, 0, 0).toLocaleDateString('en-CA')
        this.datesearch = date_t1
        this.datesearch2 = date_t2
        for (var i=0; i<12; i++){
            this.mon_arr[i].t_class =  'nav-link'
        }    
        this.mon_arr[month].t_class =  'nav-link active'

      session_var.lstream_datesearch = this.datesearch
      session_var.lstream_datesearch2 = this.datesearch2
      session_var.lstream_namesearch = this.namesearch
      session_var.lstream_lstreamsearch = this.lstreamsearch
      session_var.lstream_counterpartysearch = this.counterpartysearch
      

        axios
        .post(JsonApiURL+'api/lstream_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, lstream: this.lstreamsearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
        //.post(JsonApiURL+'api/groups_json.php', {list: {date1: date_t1, date2: date_t2, course: this.namesearch,    page: this.page,  sessionId: session_t.sessionId }})
        .then(response => { 
            this.info = response.data
            this.numPages = this.info.numPages
	        this.page = this.info.page
        })
        .catch(error => {
              console.log(error.response)
        })
     }    
    },


    lstream_create_go(){

        axios
        .post(JsonApiURL+'api/lstream_json.php', {lstream_create: {objectId: this.modal_objectId, date_begin: this.date_begin, date_end: this.date_end, date_protocol: this.date_protocol,   sessionId: session_t.sessionId }})
        .then(response => { 
            this.info9 = response.data

            axios
            .post(JsonApiURL+'api/lstream_json.php', {list: {date1: this.datesearch, date2: this.datesearch2, course: this.namesearch, status: this.status,  counterparty_id: this.counterpartysearch,  page: this.page,  sessionId: session_t.sessionId }})
            .then(response2 => { 
                this.info = response2.data
                this.numPages = this.info.numPages
	            this.page = this.info.page
            })
            .catch(error => {
                  console.log(error.response)
            })
        console.log(response)


        })
        .catch(error => {
              console.log(error.response)
        })
    },
    
    onChangeDateBegin(){
	  if( this.date_begin!='' ){
          if(this.date_begin < this.modal_date_begin)
                this.date_begin = this.modal_date_begin

          if(this.date_begin > this.modal_date_begin2)
                this.date_begin = this.modal_date_begin2

	      var currentDate = new Date(this.date_begin)
	      currentDate.setDate(currentDate.getDate() + this.modal_days )
	      this.date_end = currentDate.toLocaleDateString('en-CA')
	  }
     },
     
    onChangeDateEnd(){
	  if( this.date_end!='' ){
          if(this.date_end > this.modal_date_end)
                this.date_end = this.modal_date_end

          if(this.date_end < date_begin)
                this.date_end = this.date_begin
	  }
     },
     
     
    cohortDelete(groupId, name ){
	var fl = confirm('Удалить учебный поток: ' + name + '?');
	if(fl) {
	axios
          .post(JsonApiURL+'api/lstream_json.php', {delete: {objectId: groupId}})
          .then(response => { 
            //this.info9 = response.data
         axios
           .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, make: 0, page: this.page, sessionId: session_t.sessionId }})
           .then(response => { 
              this.info = response.data
              this.numPages = this.info.numPages
	          this.page = this.info.page
            })
           .catch(error => {
              console.log(error.response)
            })

        })
          .catch(error => {
              console.log(error.response)
            })

       }
    },
 
    lstream_unlink(cohort_id, name ){
	var fl = confirm('Убрать группу из  учебого потока: ' + name + '?');
	if(fl) {
	axios
          .post(JsonApiURL+'api/lstream_json.php', {lstream_unlink: { cohort_id: cohort_id}})
          .then(response => { 
            //this.info9 = response.data
            axios
            .post(JsonApiURL+'api/lstream_json.php', {list: { order_id: this.order_id, make: 0, page: this.page, sessionId: session_t.sessionId }})
            .then(response => { 
              this.info = response.data
              this.numPages = this.info.numPages
	          this.page = this.info.page
             })
            .catch(error => {
              console.log(error.response)
             })

           })
          .catch(error => {
              console.log(error.response)
            })

       }
    },

    documentModalArg(lstream_id, name, type_of_education_id, subtype_of_education_id, type_of_program_id, certificate1_template, certificate2_template, certificate1_name, certificate2_name, counterparty_list,  teacher_id, snils_check_sum ) {
        this.modal_lstream_id = lstream_id
        this.modal_name = name
        this.modal_counterparty_list  =  counterparty_list
console.log(this.modal_counterparty_list);
        this.modal_item = {type_of_education_id: type_of_education_id, subtype_of_education_id: subtype_of_education_id, type_of_program_id: type_of_program_id, certificate1_template: certificate1_template, certificate2_template: certificate2_template, certificate1_name: certificate1_name, certificate2_name: certificate2_name }
        this.modal_teacher_id = teacher_id
        this.import_total = 0
        this.modal_snils_check_sum = snils_check_sum
 
    },

    listModalArg(cohort_id, counterparty_id, order_id ) {
        this.modal_cohort_id = cohort_id

        axios
          .post(JsonApiURL+'api/groups_json.php', {items: {objectId: cohort_id, sessionId: session_t.sessionId } })
          .then(response => { 
                this.info5 = response.data
                this.users_list = this.info5.list
                this.modal_counterparty_id = counterparty_id
                this.modal_order_id = order_id

                console.log(response)
       })
      .catch(error => {
              console.log(error.response)
        })


    },

   handleEisotUpload() {
            this.importfile1 = document.getElementById('input_eisot').files[0];
            this.importfile1_filename = this.importfile1.name;
            this.importfile1_file_type = this.importfile1.type;
        },

    eisotSave() {
            this.wait = 1;
            this.import_total = 0;
            const formData = new FormData();
            if(this.importfile1_file_type!=''){
                formData.append('upload1', this.importfile1)
                formData.append('name1', this.importfile1_filename)
            }

            formData.append('lstream_id', this.modal_lstream_id); 
            //formData.append('cohort_id', this.cohort_id); 
            formData.append('sessionId', session_t.sessionId); 
            
	        axios
	           .post(JsonApiURL+'reports/eisot_import_json.php', formData, {headers: {'Content-Type': 'multipart/form-data'}})
               .then(response => {
                    this.info4 = response.data
                    this.wait = 0;
                    this.import_total = this.info4.result.total 
                    console.log(response)

                })
              .catch(error => {
                    console.log(error.response)
                })
         },

    displayHelpers() {
        const labels = document.querySelectorAll('label');
        const normativeSpans = document.querySelectorAll('.normative');
        labels.forEach(label => {
            const getFor = label.htmlFor;

            // добавляем подсказку
            if(getFor in this.helpers) {
               const help_block = `&nbsp;&nbsp;<a title='${this.helpers[getFor]}'><i class="fa-regular fa-circle-question text-primary"></i></a>`;
               label.innerHTML = label.innerHTML + (help_block);
            }
            // добавляем нормативку
/*            if(getFor in this.normative) {
                const help_block = `&nbsp;&nbsp;<a title='${this.normative[getFor]}'><i class="fa-solid fa-book-open text-primary"></i></a>`;
                label.innerHTML = label.innerHTML + (help_block);
            }
*/
        });
        normativeSpans.forEach(span => {
//                console.log(span.getAttribute('data-attribute'));
//                console.log(span.dataset.attribute);
                if (this.normative[span.dataset.attribute]){
                  const help_block = `&nbsp;&nbsp;<a title='${this.normative[span.dataset.attribute]}'><i class="fa-solid fa-book-open text-primary" ></i></a>`;
                  span.innerHTML = span.innerHTML + (help_block);
                }
        })

    },

    clearHelpers() {
       const normativeSpans = document.querySelectorAll('.normative');
       normativeSpans.forEach(span => {
           span.innerHTML = '';
        })

    },

    showHelper(event) {
      this.showHelperMascot = true;
      const textBox = document.querySelector('.helperMascot-message-text-box');
      console.log(this.normative[event.target.closest('span').dataset.attribute]);
      textBox.innerHTML = `<p class="helperMascot-message-text">${this.normative[event.target.closest('span').dataset.attribute]}</p>`;
      this.mascotChangePosition();
    },

    closeHelperMascot() {
        this.showHelperMascot = false;
    },

    mascotChangePosition() {
        const modalWindow  = this.$refs.modalContent;
        const mascotBlock  = this.$refs.mascot;
        const helperMascot = this.$refs.helperMascot;
        const messageBox   = this.$refs.messageBox;
        const mascotClose  = this.$refs.mascotClose;
        if(mascotBlock) mascotBlock.style.opacity = "0";

        setTimeout(() => {
          const text = document.querySelector('.helperMascot-message-text');

          console.log(modalWindow.offsetWidth);
          if(modalWindow.offsetWidth > 1139){
             helperMascot.style.height = "300px";
             messageBox.style.width = "450px";
             text.style.fontSize = "20px";
          }
          else if(modalWindow.offsetWidth > 499) {
             helperMascot.style.height = "200px";
             messageBox.style.width = "350px";
             text.style.fontSize = "18px";
          } else {
             helperMascot.style.height = "100px";
             messageBox.style.width = "250px";
             text.style.fontSize = "16px";
          }

          mascotBlock.style.left = parseInt(modalWindow.offsetWidth / 2) + "px";

          messageBox.style.right = getComputedStyle( helperMascot ).right; 
          //    messageBox.getBoundingClientRect().height);
          messageBox.style.top = -1 * parseInt( messageBox.offsetHeight ) - 10 + "px";

          mascotClose.style.left = parseInt( getComputedStyle( helperMascot ).width ) - 30 + "px";
          mascotClose.style.top = -1 * parseInt( messageBox.offsetHeight ) - 10 + "px";

          mascotBlock.style.opacity = "1";
       }, 500);

    },

},


	template: `<div><navigation></navigation><h3>Учебные потоки</h3> 

  <h4 style="text-align: center; color: red;">{{message}}</h4>

    <h4 v-if="a_lstream_id>0"  style="text-align: right;" > {{list_0_course_name}} </h4>


    <table v-if="a_lstream_id==0" >
        <tr v-if="order_id==0"  align="left">
            <td   colspan="4" style="padding-left: 0px;  padding-right: 10px;" >Начало обучения c <input type="date" v-model="datesearch" placeholder="Дата"  >  по <input type="date" v-model="datesearch2" placeholder="Дата"  ></td>
            <td style="padding-left: 10px;  padding-right: 5px;" >
		    <select  v-model="status"  id="input_status"  aria-label="Статус">
    		    <option value="0"> - статус - </option>
    		    <option v-for="item_status in status_array" :value="item_status.status_id">{{item_status.name}} </option>
		    </select>
	    </td>
        <td style="padding-left: 5px;  padding-right: 15px;"  v-if="order_id==0 && role!='counterparty'" ><small>
	        <select v-model="counterpartysearch">
	        <option value="0"> -  Организация  - </option>
            <option v-for="item2 in info2.list" :value="item2.counterparty_id">
	            {{item2.shortname.substring(0, 45)}} 
	        </option>
	        </select>
	    </small></td>
        </tr>
        <tr  align="left">
            <td colspan="5" style="padding-top: 20px; padding-right: 15px;"><input type="text" v-model="namesearch" placeholder="Курс"   size="70"   @keyup.enter="search_go(0)"></td>
            <td  style="padding-top: 20px; padding-left: 15px;  padding-right: 0px; text-align: right;" > <button  @click="search_go(0)">&nbsp;<i class="fa-solid fa-magnifying-glass"></i>&nbsp;Поиск&nbsp;</button>&nbsp;&nbsp;&nbsp;&nbsp;<button  title="Сбросить все фильтры"   @click="search_go(1)"  >&nbsp;<i class="fa-solid fa-xmark"></i>&nbsp;Сбросить фильтры&nbsp;</button> </td>
        </tr>
        <tr  align="left">
            <td  style="padding-top: 10px; padding-left: 0px;  padding-right: 5px;" ><input type="text" v-model="lstreamsearch" placeholder="Поток"   size="50"   @keyup.enter="search_go(0)"></td>
        </tr>
    </table>


    <br />
    <table class="table">
      <thead>
        <tr  align="left">
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Поток</div> </th>
          <th scope="col"> <div style="margin-right: 0px; font-size: smaller;">Период обучения</div> </th>
          <th>  <div style="margin-right: 0px; font-size: smaller;"><span v-if="a_lstream_id>0">Назначить преподавателя</span><span v-else>  Курсы</span></div> </th>
          <th scope="col" colspan="2"><div align="center" style="margin-right: 0px; font-size: smaller;">Список <br />заказчиков / слушателей</div>  </th>
          <th scope="col"><div align="center" style="margin-right: 0px; font-size: smaller;">Личное <br />дело</div>  </th>
          <th scope="col"><div v-if="this.is_LMS>0" align="center" style="margin-right: 0px; font-size: smaller;">Синхронизация с LMS </th>

        </tr>
      </thead>
     <tbody>   
        <tr v-for="item in info.list"  align="left" >  
            <td style="padding-left: 0px; padding-right: 10px;" >
                <!--<table border="0"><tr><td valign="middle" style="padding-left: 0px; padding-right: 7px;" ><nobr>{{item.name}}&nbsp;&nbsp;<i>({{item.count}} чел.)</i></nobr></td></tr></table>-->
                <nobr>{{item.name}}&nbsp;&nbsp;<i style="color: #555;">({{item.count}} чел.)</i></nobr>
              
                  
                
            </td>
            <td  style="padding-left: 10px; padding-right: 10px;"  >
                <small>{{new Date(item.date_begin).toLocaleDateString("ru")}} <!--<br /><small>-</small>--> <br />{{new Date(item.date_end).toLocaleDateString("ru")}}</small> 
            </td>
            <td  style="padding-left: 10px; padding-right: 10px;"  >{{item.course_name}} 
               <nobr>
                <router-link  :to="{ name: 'lstream_edit', params: {lstreamid: item.lstream_id, orderid: this.order_id}}" title="Редактировать настройки" ><i class="fa-solid fa-pencil"></i></router-link>
                &nbsp;&nbsp;<span v-if="item.scheduler_count>0 && false"><router-link :to=""  title="Календарь" ><i class="fa-solid fa-calendar-day"></i></router-link><span style="color: green;">&nbsp;<i class="fa-solid fa-check"></i></span></span>
               </nobr>
            </td>
            <td align="right" style="padding-top: 7px; padding-right: 1px;"   >
                <div  style="padding-top: 5px;" class="dropdown">
                    <button class="btn btn-link btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"> <i class="fa-solid fa-folder-tree"></i> </button>
                    <ul class="dropdown-menu"  style="--bs-dropdown-min-width: 30rem;">
                        <!--<li  v-for="item2 in item.counterparty_list"><router-link class="dropdown-item" :to="{ name: 'orders_list', params: {counterpartyid: item2.counterparty_id, orderid: item2.order_id }}" title="Заявки" ><small>{{item2.shortname}}</small></router-link></li>-->
                        <li  v-for="item2 in item.counterparty_list">
