       userCounterpartyDelete(userCounterpartyId, name ){ 
	var fl = confirm('Удалить должность: ' + name + '?');
	if(fl) {
	    axios
          .post(JsonApiURL+'api/students_json.php', {delete_user_counterparty: {userCounterpartyId: userCounterpartyId}})
          .then(response => { 
               console.log(response)
            //this.info9 = response.data


                axios
                    .post(JsonApiURL+'api/students_json.php', {user_jobs: {objectId: this.user_id, sessionId: session_t.sessionId } })
                    .then(response2 => { 
                        this.info3 = response2.data
                        this.jobs = this.info3.result
                        this.jobs_count = this.jobs.length
                        if(this.jobs_count>0){
                             this.user_counterparty_id = this.jobs[0].user_counterparty_id
                        }
                        else {
                             this.user_counterparty_id = 0
                        }

                    })
                   .catch(error => {
                        console.log(error.response)
                    })


        })
        .catch(error => {
              console.log(error.response)
        })

      }
