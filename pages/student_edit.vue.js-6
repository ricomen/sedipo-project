        onChangeUser(){
           if(this.sex == ''){
	    if(this.lastname != '' ) {
                if(this.lastname[this.lastname.length-1] == 'а')
                    this.sex = 'Жен'
                else if(this.lastname[this.lastname.length-1] == 'в')
                    this.sex = 'Муж'
            }
            if(this.middlename != '' ) {
                if(this.middlename[this.middlename.length-1] == 'ч')
                    this.sex = 'Муж'
                else
                    this.sex = 'Жен'
            }
          }
        },

