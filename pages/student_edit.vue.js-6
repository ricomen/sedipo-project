  methods: {
     validateSnils() 
    {
      this.snilsError = ''
      
      // Очистка от лишних символов
      const cleanSnils = this.snils.replace(/\D/g, '')
      
      // Проверка длины
      if (cleanSnils.length !== 11) {
        this.snilsError = 'СНИЛС должен содержать 11 цифр'
        //return
      }

      // Проверка контрольной суммы
      if (!this.checkSnilsControlSum(cleanSnils)) {
        this.snilsError = 'некорректный СНИЛС'
      }
    },

    checkSnilsControlSum(snils) {
      const digits = snils.split('').map(Number)
      const controlSum = digits.slice(-2).join('')
      const numbers = digits.slice(0, 9)

      // Расчет контрольной суммы
      let calculatedSum = 0
      for (let i = 0; i < numbers.length; i++) {
        calculatedSum += numbers[i] * (9 - i)
      }

      // Проверка особых случаев
      if (calculatedSum > 101) {
        calculatedSum %= 101
      }
      if (calculatedSum === 100 || calculatedSum === 101) {
        calculatedSum = 0
      }

      // Форматирование в двузначную строку
      const formattedCalculatedSum = calculatedSum.toString().padStart(2, '0')

      return formattedCalculatedSum === controlSum
    },
