    <input v-model="password"   id="input_password"    type="hidden"  >
  </p>


  <div class="mb-2 row">
      <label for="input_user_status" class="form-label col-sm-1">Статус  </label>
	    <select  v-model="user_status_id"  id="input_user_status" class="form-select col" aria-label="user_status">
	    <option value="0"> Активная запись </option>
	    <option value="1"> Архив </option>
	    </select>
    <div class="col-8"> </div>
  </div>


  <div class="mb-2">	
    <div align="right">
    <button  class="btn btn-primary"    @click="userSave()"> Сохранить </button>
    <span v-if="a_order_id>0">
      &nbsp<router-link :to="{ name: 'order_items', params: {orderid: a_order_id  }}"><button  class="btn btn-outline-primary">Отмена</button></router-link>
    </span>
    <span v-else-if="a_group_id>0">
      &nbsp<router-link :to="{ name: 'group_items', params: {groupid: a_group_id, orderid: 0 }}"><button  class="btn btn-outline-primary">Отмена</button></router-link>
    </span>
    <span v-else>
      &nbsp<router-link :to="{ name: 'students_list', params: {counterpartyid: a_counterparty_id  }}" ><button  class="btn btn-outline-primary">Отмена</button></router-link>
    </span>
    </div>
  </div>

 </div>
 <div v-if="view_link_button >0 && a_order_id>0" class="col-2">
   <p>{{user2_lastname}}<br />
   {{user2_firstname}}<br />
   {{user2_middlename}}</p>
   <p v-if="user2_job_title_name!=''">Должность: <br />{{user2_job_title_name}}</p>
    <div align="right">
     <span v-if="view_link_button >0 ">
        <button class="btn btn-success"  type="primary"  @click="userUse()"> Использовать существующую учетную запись </button>
     </span>
    </div>
</div>

</div>
	</div>`

};




