		                }
		                else {
                            this.$router.push({ name: 'students_list', params: {counterpartyid: this.a_counterparty_id  }}) 
		                }

                    }
                    else {
                        this.message = response.data.error
                    }
                })
                .catch(error => {
                  console.log(error.response)
                })
            }

