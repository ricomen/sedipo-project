    search_go(fl) {
    var conditions = {}

    if(fl == 0)
         this.namesearch = "";

    if(this.category>0){
        conditions =  {"category_id": this.category, "main_module": 0 }
    }
    else {
        conditions = {}
    }

    this.seachcount = 0 
    this.msg_result = ''

    if( this.namesearch != '' ){
      axios
         .post(JsonApiURL+'api/courses_json.php', {list: {conditions, search: this.namesearch,   sessionId: session_t.sessionId }}, {withCredentials: true})
         .then(response => { 
            this.info2 = response.data
            this.seachcount = this.info2.list.length
              console.log(response.data)
          })
         .catch(error => {
              console.log(error.response)
         })
      }
    },


    categories_go() {
    this.msg_result = ''
    var filter = ''
    this.is_modules = 0
    this.course = 0 
  
    if(this.category>0) {
            filter =  "`category_id`="+this.category+" AND `main_module`=0";
            //this.is_rank_of_profession = this.info4.list[this.info4.list.findIndex(item => item.category_id == this.category)].is_rank_of_profession
            this.is_modules = this.info4.list[this.info4.list.findIndex(item => item.category_id == this.category)].modules
    }     
    /*else {
        filter = "`main_module`=0";
        if(this.course>0){
            var current_category = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].category_id
            this.is_rank_of_profession = this.info4.list[this.info4.list.findIndex(item => item.category_id == current_category)].is_rank_of_profession
            this.is_modules = this.info4.list[this.info4.list.findIndex(item => item.category_id == current_category)].modules
        }
    }*/      
 
    if(this.category>0) {
        axios
          .post(JsonApiURL+'api/courses_json.php', {list: {where: filter,  sessionId: session_t.sessionId }}, {withCredentials: true})
          .then(response => { 
                this.info2 = response.data
                //this.parent_txt =  this.info.categories_txt
                //this.parent = this.info.parent_id
            })
            .catch(error => {
              console.log(error.response)
            })
      }
    
    },
    
    course_go() {
        this.msg_result = ''
        this.rank_of_profession = 0
        //this.is_rank_of_profession = 0


        if(this.course>0){
            this.rank_of_profession = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].rank_of_profession
            this.variation1_title = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].hours.replace(/[^0-9]/g, "")
            this.variation2_title = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].hours_add.replace(/[^0-9]/g, "")
            this.variation3_title = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].hours_add2.replace(/[^0-9]/g, "")
        }

        axios
          .post(JsonApiURL+'api/orders_json.php', {user_course_check: { user_course_check: this.user_check.toString(), check_id: this.check_id.toString(), check_item_id: this.check_item_id.toString(),  course_id: this.course,   variation: this.variation,  sessionId: session_t.sessionId }}, {withCredentials: true})
          .then(response => { 
                console.log(response)
                this.info7 = response.data

                var index = 0
                for (var item in this.info5.list) {
                   if( this.info7.result[index]>0 ){
                      var fl = confirm( 'Пользователь: ' + this.info5.list[item].lastname + ' ' + this.info5.list[item].firstname + ' ' + this.info5.list[item].middlename + ' - ' +  this.info5.list[item].job_title + ' уже записан или проходил обучение по этому курсу.  Записать повторно?' ) 
                      if( !fl ) {
                          this.user_check[index] = false
                      }
                   }
                   index++
                }


            })
          .catch(error => {
              console.log(error.response)
            })

        //if(this.category>0 && this.rank_of_profession==0 ){
        //    this.is_rank_of_profession = this.info4.list[this.info4.list.findIndex(item => item.category_id == this.category)].is_rank_of_profession
        //}
        /*else {
            var current_category = this.info2.list[this.info2.list.findIndex(item => item.course_id == this.course)].category_id
            this.is_rank_of_profession = this.info4.list[this.info4.list.findIndex(item => item.category_id == current_category)].is_rank_of_profession
            this.is_modules = this.info4.list[this.info4.list.findIndex(item => item.category_id == current_category)].modules
        }*/
    },

    userUnlink( name , itemId){
	var fl = confirm('Исключить: ' + name + '?');
	    if(fl && itemId>0) {
	    axios
             .post(JsonApiURL+'api/orders_json.php', {item_del: {objectId:  this.order_id,  item_id: itemId,  sessionId: session_t.sessionId }}, {withCredentials: true})
             .then(response => { 
	         console.log(response)
            //this.info = response.data

    	        axios
    		    .post(JsonApiURL+'api/orders_json.php', {items: {objectId: this.order_id, sessionId: session_t.sessionId } }, {withCredentials: true})
    		    .then(response5 => { 
        	         console.log(response5)
        	         this.info5 = response5.data
                         this.consulting = this.info5.consulting_list.length
                         this.balance = this.info5.balance
                         this.check_id = []
                         this.check_item_id = []
                         this.users_count = this.info5.list.length
                         for (var i = 0; i < this.users_count; i++) {
                                if(this.info5.list[i].course_list.length > this.course_count)
                                    this.course_count = this.info5.list[i].course_list.length 
                         }
                         for (var i = 0; i < this.users_count; i++) {
                               this.check_id.push(this.info5.list[i].user_id)
                               this.check_item_id.push(this.info5.list[i].item_id)

                               for (var j = 0;  j <  this.info5.list[i].course_list.length; j++ ) {
                                     var is_blank = this.info5.list[i].course_list[j].is_blank
                                     if(this.info5.list[i].course_list[j].is_blank)
                                         this.blank_number[i*(this.course_count+1) + j] = this.info5.list[i].course_list[j].blank_number
                                     else
                                         this.blank_number[i*(this.course_count+1) + j] = ''

                                     this.custom_cert_number[i*(this.course_count+1) + j] = this.info5.list[i].course_list[j].custom_cert_number


                                     var course_id = this.info5.list[i].course_list[j].course_id
                                     var group_number = this.info5.list[i].course_list[j].group_number
                                     var index0 = -1
                                     for (var k = 0;  k <  this.custom_protocol_c_id.length; k++ ) {
                                           if(this.custom_protocol_c_id[k] == course_id){
                                                 index0 = k;
                                                 break;
                                           }
                                     }
                                     if(index0 < 0 &&  course_id>0 ){
                                         var k = this.custom_protocol_c_id.length
                                         this.custom_protocol_c_id[k] = course_id
                                         this.custom_protocol_c_g_n[k] = group_number
                                         this.group_number_i.push( this.info5.list[i].course_list[j].group_number )
                                         index0 = this.custom_protocol_c_id.length -1
                                     }
                                     this.custom_protocol_index[i*(this.course_count+1) + j] = index0 
                               }
                         }
                         for (var i = 0; i < this.info5.group_list.length; i++) {
                             for (var k = 0;  k <  this.custom_protocol_c_id.length; k++ ) {
                                   if(this.custom_protocol_c_id[k] == this.info5.group_list[i].course_id){
                                         this.custom_protocol_number[k] = this.info5.group_list[i].custom_protocol_num;
                                         break;
                                   }
                             }

                         }


    		    })
    		    .catch(error => {
            	         console.log(error.response)
                    })

            })
          .catch(error => {
              console.log(error.response)
            })

	    }
    },

