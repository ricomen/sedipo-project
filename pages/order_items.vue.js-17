    checkall(){
       this.msg_result = ''

        if( this.check_all ) {
            this.user_check = []
        }
        else {
             for (item in this.check_id) {
                         this.user_check[item] = true
            }
        }
    },

   reserve_seats(){
           this.student_a =  false

	    axios
             .post(JsonApiURL+'api/orders_json.php', {reserve_seats: {objectId:  this.order_id,  number_of_people:  this.number_of_people, sessionId: session_t.sessionId }}, {withCredentials: true})
             .then(response => { 
	         console.log(response)
            //this.info9 = response.data

    	        axios
    		    .post(JsonApiURL+'api/orders_json.php', {items: {objectId: this.order_id, sessionId: session_t.sessionId } }, {withCredentials: true})
    		    .then(response5 => { 
        	         console.log(response5)
        	         this.info5 = response5.data
                         this.balance = this.info5.balance
                         this.consulting = this.info5.consulting_list.length
                         this.check_id = []
                         this.check_item_id = []
                         for (item in this.info5.list) {
                               this.check_id.push(this.info5.list[item].user_id)
                               this.check_item_id.push(this.info5.list[item].item_id)
