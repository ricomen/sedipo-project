     }
   },


   mounted() {
    this.order_id = Number(this.$route.params.orderid)
    this.a_counterparty_id = Number(this.$route.params.counterpartyid)
    if(isNaN(this.a_counterparty_id))
        this.a_counterparty_id = 0

    if(this.order_id>0) { 
        axios
    	    .post(JsonApiURL+'api/orders_json.php', {object: {objectId: this.order_id, sessionId: session_t.sessionId } }, {withCredentials: true})
            .then(response => { 
                this.info = response.data
                this.role = this.info.role
                this.date_order = this.info.result.date_order
                this.number_order = this.info.result.number
                this.counterparty_id  = this.info.result.counterparty_id
                this.status_id = this.info.result.status_id
                this.date_begin = this.info.result.date_begin
                this.date_end = this.info.result.date_end

                if( this.role=='counterparty' )
                        this.print_v = 'false'

                if(this.counterparty_id > 0) {
    	            axios
    		     .post(JsonApiURL+'api/counterparty_json.php', {object: {objectId: this.counterparty_id, sessionId: session_t.sessionId } }, {withCredentials: true})
    		     .then(response3 => { 
        	         console.log(response3)
        	         this.info3 = response3.data
    		     })
    		     .catch(error => {
            	         console.log(error.response)
        	     })
                }

                axios
    		    .post(JsonApiURL+'api/orders_json.php', {items: {objectId: this.order_id, sessionId: session_t.sessionId } }, {withCredentials: true})
    		    .then(response5 => { 
        	         console.log(response5)
        	         this.info5 = response5.data
                         this.consulting = this.info5.consulting_list.length
                         this.balance = this.info5.balance
                         this.check_id = []
                         this.check_item_id = []
                         this.users_count = this.info5.list.length
                         for (var i = 0; i < this.users_count; i++) {
                                if(this.info5.list[i].course_list.length > this.course_count)
                                    this.course_count = this.info5.list[i].course_list.length 
                         }
                         for (var i = 0; i < this.users_count; i++) {
                               this.check_id.push(this.info5.list[i].user_id)
                               this.check_item_id.push(this.info5.list[i].item_id)

                               for (var j = 0;  j <  this.info5.list[i].course_list.length; j++ ) {
                                     var is_blank = this.info5.list[i].course_list[j].is_blank
                                     if(this.info5.list[i].course_list[j].is_blank)
                                         this.blank_number[i*(this.course_count+1) + j] = this.info5.list[i].course_list[j].blank_number
                                     else
                                         this.blank_number[i*(this.course_count+1) + j] = ''

                                     this.custom_cert_number[i*(this.course_count+1) + j] = this.info5.list[i].course_list[j].custom_cert_number


                                     var course_id = this.info5.list[i].course_list[j].course_id
                                     var group_number = this.info5.list[i].course_list[j].group_number
                                     var index0 = -1
                                     for (var k = 0;  k <  this.custom_protocol_c_id.length; k++ ) {
                                           if(this.custom_protocol_c_id[k] == course_id){
                                                 index0 = k;
                                                 break;
                                           }
                                     }
                                     if(index0 < 0 &&  course_id>0 ){
                                         var k = this.custom_protocol_c_id.length
                                         this.custom_protocol_c_id[k] = course_id
                                         this.custom_protocol_c_g_n[k] = group_number
                                         this.group_number_i.push( this.info5.list[i].course_list[j].group_number )
                                         index0 = this.custom_protocol_c_id.length -1
                                     }
                                     this.custom_protocol_index[i*(this.course_count+1) + j] = index0 
                               }
                         }
                         for (var i = 0; i < this.info5.group_list.length; i++) {
                             for (var k = 0;  k <  this.custom_protocol_c_id.length; k++ ) {
                                   if(this.custom_protocol_c_id[k] == this.info5.group_list[i].course_id){
                                         this.custom_protocol_number[k] = this.info5.group_list[i].custom_protocol_num;
                                         break;
                                   }
                             }

                         }
    		    })
    		    .catch(error => {
            	         console.log(error.response)
                    })


           })
          .catch(error => {
              console.log(error.response)
            }),
  

            axios
            .post(JsonApiURL+'api/course_category_json.php', {list: {conditions: {"consulting": 0}, sessionId: session_t.sessionId }}, {withCredentials: true})
            .then(response => { 
                this.info4 = response.data
            })
                .catch(error => {
              console.log(error.response)
            }),
            
            axios
            .post(JsonApiURL+'api/course_category_json.php', {list: {conditions: {"consulting": 1},  sessionId: session_t.sessionId }}, {withCredentials: true})
            .then(response => { 
                //this.info6 = response.data
                var category1 = response.data.list[0].category_id
                axios
                .post(JsonApiURL+'api/courses_json.php', {list: {conditions: {"category_id": category1},  sessionId: session_t.sessionId }}, {withCredentials: true})
                .then(response => { 
                      this.info6 = response.data
                })
                .catch(error => {
                      console.log(error.response)
                })
                
                
            })
            .catch(error => {
                console.log(error.response)
            })

/*           axios
              .post(JsonApiURL+'api/groups_json.php', {list: { order_id: this.order_id, make: 0,  page: this.page,  sessionId: session_t.sessionId }})
              .then(response => { 
                  this.info8 = response.data
 
                  var i = 0
                  for (item in this.info8.list) {
                         this.custom_protocol_number[i] = this.info8.list[item].custom_protocol_number
                          i++
                  }
                 console.log(response)
             })
                .catch(error => {
                console.log(error.response)
            })
*/

            //axios
            //.post(JsonApiURL+'api/courses_json.php', {list: {where: "`main_module`=0",  sessionId: session_t.sessionId }})
            //.then(response => { 
              //  this.info2 = response.data
            //})
            //.catch(error => {
              //  console.log(error.response)
            //})

      }

  },


