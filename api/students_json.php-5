/* USERS */

function users_list($counterparty_id,  $lastname, $firstname, $middlename, $status,   $page) {
    global $api_arg, $user_id_session, $session_role,  $dbh;
    global $page_size;

    $offset=0;
    if( $page>1 ){
	    $offset = intval($page-1)*$page_size;
    }
    $num_pages = 1;

    $users_list = [];
    $members = 0;
    $addsearch = '';

    if($lastname!='' || $firstname!='' ||  $middlename!='' ){
	    if($counterparty_id>0){
	        $stmt = $dbh->prepare('SELECT DISTINCT `user_id`, `login`, `lastname`, `firstname`, `middlename`  FROM `a_users`  LEFT JOIN `a_user_counterparty` USING (`user_id`) WHERE `lastname` LIKE ? AND `firstname` LIKE ? AND  `middlename` LIKE ? AND `counterparty_id`=? AND `a_users`.`status`=? AND `a_users`.`user_id`>1  ORDER BY `lastname` LIMIT '.$page_size.'  OFFSET  ' . "$offset");
	        $stmt->execute(["$lastname%", "$firstname%", "$middlename%", $counterparty_id, $status]);
	    }
	    else {
	        $stmt = $dbh->prepare('SELECT DISTINCT `user_id`, `lastname`, `firstname`, `middlename`   FROM `a_users` WHERE `lastname` LIKE ? AND `firstname` LIKE ? AND  `middlename` LIKE ? '. $addsearch .'  AND `a_users`.`status`=?  AND `a_users`.`user_id`>1   ORDER BY `lastname` LIMIT '.$page_size.'  OFFSET  ' . "$offset");
    	        $stmt->execute(["$lastname%", "$firstname%", "$middlename%", $status]);
	    }
    }
    else {
	    if($counterparty_id>0){
	        $stmt = $dbh->prepare('SELECT DISTINCT  `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`  FROM `a_users` LEFT JOIN `a_user_counterparty` USING (`user_id`)  WHERE  `counterparty_id`=?   AND `a_users`.`status`=?  AND `a_users`.`user_id`>1    ORDER BY `lastname` LIMIT '.$page_size.'  OFFSET  ' . "$offset");
    	        $stmt->execute([ $counterparty_id, $status]);
	    }
	    else {
	        $stmt = $dbh->prepare('SELECT DISTINCT  `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`  FROM `a_users`   WHERE `a_users`.`status`=?  AND `a_users`.`user_id`>1    ORDER BY `lastname`  LIMIT '.$page_size.'  OFFSET  ' . "$offset");
    	        $stmt->execute([ $status]);
	    }
    }
    while($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
         $jobs = [];
         if($counterparty_id>0){
             $stmt1 = $dbh->prepare('SELECT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=? AND `counterparty_id`=?  AND `status`=0  ');
             $stmt1->execute([ $row->user_id, $counterparty_id ]);
         }
         else {
             $stmt1 = $dbh->prepare('SELECT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=?  AND `status`=0  ');
             $stmt1->execute([ $row->user_id ]);
         }
         while($row1 = $stmt1->fetch(PDO::FETCH_OBJ)) {
            $job_title_name = '';
            if($row1->job_title_id >0 ){
                $stmt2 = $dbh->prepare('SELECT  `name`  FROM `a_job_title`  WHERE `job_title_id`=? ');
                $stmt2->execute([$row1->job_title_id]);
                if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
                    $job_title_name = $row2->name;
                }
            }

            $counterparty_name = '';
            if($row1->counterparty_id >0 ){
                $stmt3 = $dbh->prepare('SELECT  `shortname`, `name`  FROM `a_counterparty`  WHERE `counterparty_id`=? ');
                $stmt3->execute([$row1->counterparty_id]);
                if($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {
                    $counterparty_name = $row3->shortname;
               }
            }
            $jobs[] = [  "user_counterparty_id"=>$row1->user_counterparty_id,  "counterparty_id"=>$row1->counterparty_id, "counterparty_name"=>$counterparty_name, "counterparty_fullname"=>$row3->name,  "job_title_id"=>$row1->job_title_id,  "job_title"=>$job_title_name,   "job_title_category"=>$row1->job_title_category,   "subdivision"=>$row1->subdivision ];
        }
        $orders_count = 0;
        $stmt2 = $dbh->prepare('SELECT count(*)  as `count`   FROM `a_users` LEFT JOIN `a_user_counterparty` USING(`user_id`) LEFT JOIN `a_order_users`  USING(`user_counterparty_id`)  LEFT JOIN `a_order` USING(`order_id`)   WHERE `user_id`=?  AND `a_order`.`status_id`<15  ');
        $stmt2->execute([ $row->user_id ]);
        if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
              $orders_count = $row2->count;
        }

        $users_list[] =  ["userId"=>$row->user_id,  "lastname"=>$row->lastname, "firstname"=>$row->firstname, "middlename"=>$row->middlename, "jobs"=>$jobs, "orders_count"=>$orders_count ];
    }


    if($lastname!='' || $firstname!='' ||  $middlename!='' ){
	    if($counterparty_id>0){
	        $stmt0 = $dbh->prepare('SELECT  count(DISTINCT `a_users`.`user_id` )  as `count`   FROM `a_users`  LEFT JOIN `a_user_counterparty` USING (`user_id`) WHERE  `lastname` LIKE ? AND `firstname` LIKE ? AND  `middlename` LIKE ? AND `counterparty_id`=? AND `a_users`.`status`=? AND `a_users`.`user_id`>1  ' );
	        $stmt0->execute(["$lastname%", "$firstname%", "$middlename%", $counterparty_id, $status]);
	    }
	    else {
	        $stmt0 = $dbh->prepare('SELECT  count(DISTINCT `a_users`.`user_id` )  as `count`    FROM `a_users` WHERE `lastname` LIKE ? AND `firstname` LIKE ? AND  `middlename` LIKE ? '. $addsearch .'  AND `a_users`.`status`=? AND `a_users`.`user_id`>1  ');
    	        $stmt0->execute(["$lastname%", "$firstname%", "$middlename%", $status]);
	    }
    }
    else {
	    if($counterparty_id>0){
	        $stmt0 = $dbh->prepare('SELECT  count(DISTINCT `a_users`.`user_id` )  as `count`   FROM `a_users` LEFT JOIN `a_user_counterparty` USING (`user_id`)  WHERE  `counterparty_id`=?   AND `a_users`.`status`=?  AND `a_users`.`user_id`>1  ');
    	        $stmt0->execute([ $counterparty_id, $status]);
	    }
	    else {
	        $stmt0 = $dbh->prepare('SELECT  count(DISTINCT `a_users`.`user_id` )  as `count`   FROM `a_users`   WHERE `a_users`.`status`=? AND `a_users`.`user_id`>1  ');
    	        $stmt0->execute([ $status]);
	    }
    }
    if($row0 = $stmt0->fetch(PDO::FETCH_OBJ)) {  
	    $members = $row0->count;
    }
    $num_pages = intval(($members+0.5)/$page_size+1);
    if( $page > $num_pages ){
            $page = $num_pages;
    }
    if( $page == 0 ){
            $page = 1;
    }


    $counterparty_list = [];
    if(($lastname!='' || $firstname!='' ||  $middlename!='') && $counterparty_id==0 ){
        $stmt3 = $dbh->prepare('SELECT DISTINCT `a_user_counterparty`.`counterparty_id`, `shortname`  FROM `a_users`  LEFT JOIN `a_user_counterparty` USING (`user_id`) LEFT JOIN `a_counterparty` USING (`counterparty_id`)  WHERE  `lastname` LIKE ? AND `firstname` LIKE ? AND  `middlename` LIKE ?  AND `a_users`.`status`=?  ORDER BY `shortname` LIMIT 100');
        $stmt3->execute(["$lastname%", "$firstname%", "$middlename%", $status]);
        while($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {
            $counterparty_list[] = ["counterparty_id"=>$row3->counterparty_id, "counterparty_name"=>$row3->shortname];
        }
    }



    $result = ["role"=>$session_role, "action"=>"list",  "list"=>$users_list, "counterparty_list"=>$counterparty_list,  "numPages"=>$num_pages, "page"=>$page];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function user_object($user_id, $counterparty_id) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    $rc =  ["user_id"=>0,  "lastname"=>'', "firstname"=>'', "middlename"=>'', "email"=>'', "login"=>'',  "password"=>'', "counterparty_id"=>0, "job_title_id"=>0,  "job_title"=>'', "subdivision"=>'', "date_of_birth"=>'', "snils"=>'', "inn"=>'', "phone"=>'', "address"=>'', "sex"=>''  ];
    if($user_id >1 ) {
            if($counterparty_id>0){
	         $stmt = $dbh->prepare('SELECT  `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`, `email`, `counterparty_id`,  `date_of_birth`, `snils`, `inn`,  `phone`, `address`,  `diplom_filename`, `diplomfile`, `photo_filename`, `sex`, `level_of_education`, `dplom_series`, `diplom_number`, `diplom_lastname`, `citizenship`, `pasport_series`, `pasport_number`, `pasport_unit_number`, `pasport_unit`, `comment`,  `photofile`, `a_users`.`status` FROM `a_users`   LEFT JOIN `a_user_counterparty` USING (`user_id`)   WHERE `a_users`.`user_id`=? AND `counterparty_id`=? ');
                 $stmt->execute([$user_id, $counterparty_id]);
            }
            else{
	         $stmt = $dbh->prepare('SELECT  `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`, `email`, `counterparty_id`,  `date_of_birth`, `snils`, `inn`,  `phone`, `address`,  `diplom_filename`, `diplomfile`, `photo_filename`, `sex`, `level_of_education`, `dplom_series`, `diplom_number`, `diplom_lastname`, `citizenship`, `pasport_series`, `pasport_number`, `pasport_unit_number`, `pasport_unit`, `comment`,  `photofile`, `a_users`.`status` FROM `a_users`   LEFT JOIN `a_user_counterparty` USING (`user_id`)   WHERE `a_users`.`user_id`=?');
                 $stmt->execute([$user_id]);
            }
	    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
                $orders_count = 0;
                $stmt2 = $dbh->prepare('SELECT count(*)  as `count`   FROM `a_users` LEFT JOIN `a_user_counterparty` USING(`user_id`) LEFT JOIN `a_order_users`  USING(`user_counterparty_id`)  LEFT JOIN `a_order` USING(`order_id`)   WHERE `user_id`=?  AND `a_order`.`status_id`<15  ');
                $stmt2->execute([ $row->user_id ]);
                if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
                   $orders_count = $row2->count;
                }

                $rc =  ["user_id"=>$row->user_id, "lastname"=>$row->lastname, "firstname"=>$row->firstname, "middlename"=>$row->middlename, "email"=>$row->email,  "date_of_birth"=>$row->date_of_birth, "snils"=>$row->snils, "inn"=>$row->inn, "phone"=>$row->phone, "address"=>$row->address,  "status"=>$row->status,   "diplom_filename"=>$row->diplom_filename, "diplomfile"=>$row->diplomfile, "photo_filename"=>$row->photo_filename, "photofile"=>$row->photofile, "sex"=>$row->sex,  "level_of_education"=>$row->level_of_education,  "dplom_series"=>$row->dplom_series, "diplom_number"=>$row->diplom_number, "diplom_lastname"=>$row->diplom_lastname, "citizenship"=>$row->citizenship, "pasport_series"=>$row->pasport_series, "pasport_number"=>$row->pasport_number, "pasport_unit_number"=>$row->pasport_unit_number, "comment"=>$row->comment, "pasport_unit"=>$row->pasport_unit, "orders_count"=>$orders_count ];
	    }
    }
    $result = ["role"=>$session_role, "action"=>"user",  "result"=>$rc ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function user_jobs($user_id, $counterparty_id, $status) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    $jobs = [];
    if($user_id >1 ) {
        if($counterparty_id>0){
             $stmt1 = $dbh->prepare('SELECT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=? AND `counterparty_id`=? AND `status`=? ');
             $stmt1->execute([ $user_id, $counterparty_id, $status ]);
        }
        else {
             $stmt1 = $dbh->prepare('SELECT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=?  AND `status`=? ');
             $stmt1->execute([ $user_id, $status  ]);
        }
        while($row1 = $stmt1->fetch(PDO::FETCH_OBJ)) {
            $job_title_name = '';
            if($row1->job_title_id >0 ){
                $stmt2 = $dbh->prepare('SELECT  `name`  FROM `a_job_title`  WHERE `job_title_id`=? ');
                $stmt2->execute([$row1->job_title_id]);
                if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
                      $job_title_name = $row2->name;
                }
            }

            $counterparty_name = '';
            if($row1->counterparty_id >0 ){
                $stmt3 = $dbh->prepare('SELECT  `shortname`, `name`  FROM `a_counterparty`  WHERE `counterparty_id`=? ');
                $stmt3->execute([$row1->counterparty_id]);
                if($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {
                    $counterparty_name = $row3->shortname;
                }
            }

            $orders_count = 0;
            $stmt2 = $dbh->prepare('SELECT count(*)  as `count`   FROM `a_users` LEFT JOIN `a_user_counterparty` USING(`user_id`) LEFT JOIN `a_order_users`  USING(`user_counterparty_id`)  LEFT JOIN `a_order` USING(`order_id`)   WHERE `user_id`=?  AND `a_order`.`status_id`<15  ');
            $stmt2->execute([ $user_id ]);
            if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
               $orders_count = $row2->count;
            }

            $jobs[] = [ "user_counterparty_id"=>$row1->user_counterparty_id,   "counterparty_id"=>$row1->counterparty_id, "counterparty_name"=>$counterparty_name,   "job_title_id"=>$row1->job_title_id,  "job_title"=>$job_title_name,   "job_title_category"=>$row1->job_title_category,   "subdivision"=>$row1->subdivision, "orders_count"=>$orders_count ];
        }
    }
    $result = ["role"=>$session_role, "action"=>"user_jobs",  "result"=>$jobs ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}




function user_search( $order_id, $counterparty_id,  $lastname, $firstname, $middlename, $snils, $exclude_user_id ) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    if($lastname=='' ){
         $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"serch1",   "result"=>["user_id"=>-2, "counterparty_id"=>$counterparty_id]];
         echo json_encode($result, JSON_UNESCAPED_UNICODE);
         return;
    }

    $search_filter = ''; 
    if($order_id>0){
        $counterparty_id = 0;
        $stmt0 = $dbh->prepare('SELECT  `counterparty_id`  FROM `a_order`   WHERE `order_id`=?');
        $stmt0->execute([$order_id]);
        if($row0 = $stmt0->fetch(PDO::FETCH_OBJ)) {  
                $counterparty_id =  $row0->counterparty_id;
        }
//        $order_filter = 'AND `user_id` NOT IN ( SELECT  DISTINCT  `a_users`.`user_id` FROM `a_order_users`  LEFT JOIN `a_user_counterparty` USING (`user_counterparty_id`) LEFT JOIN `a_users` USING(`user_id`) WHERE   `order_id` = ' .$order_id. ' AND `a_users`.`status`=0 ) '; 
    }
    if( $snils!='' ){ 
        $search_filter = ' AND `a_users`.`snils` LIKE "' . $snils .'%"'; 
    }
    if( $exclude_user_id>0 ){ 
        $search_filter = $search_filter . ' AND `a_users`.`user_id`<>' . $exclude_user_id ; 
    }


    $rc = ["user_id"=>-1, "counterparty_id"=>$counterparty_id];

    if( $counterparty_id>0 || strlen(trim($snils))>=11 ){ 

      if( $counterparty_id>0 ){ 
        $stmt = $dbh->prepare('SELECT DISTINCT `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`,  `snils`, `user_counterparty_id`    FROM `a_users`  LEFT JOIN `a_user_counterparty` USING (`user_id`)     WHERE  `counterparty_id`=? AND `lastname` LIKE ? AND `firstname` LIKE ? AND `middlename` LIKE ? AND `a_users`.`status`=0 '.$search_filter.' ORDER BY `user_id`  LIMIT 2');
        $stmt->execute([ $counterparty_id,  "$lastname%", "$firstname%", "$middlename%"  ]);
      }
      else {
        $stmt = $dbh->prepare('SELECT DISTINCT `a_users`.`user_id`,  `lastname`, `firstname`, `middlename`,  `snils`, `user_counterparty_id`    FROM `a_users`  LEFT JOIN `a_user_counterparty` USING (`user_id`)     WHERE  `lastname` LIKE ? AND `firstname` LIKE ? AND `middlename` LIKE ?  AND `a_users`.`status`=0 AND LENGTH(`snils`)>=11 '.$search_filter.' ORDER BY `user_id`  LIMIT 2');
        $stmt->execute([  "$lastname%", "$firstname%", "$middlename%"  ]);
      }
      if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
        $jobs = [];
        if($row->user_id >1 ) {
            if($counterparty_id>0){
                 $stmt1 = $dbh->prepare('SELECT DISTINCT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=? AND `counterparty_id`=? AND `status`=0 ');
                 $stmt1->execute([ $row->user_id, $counterparty_id ]);
            }
            else {
                 $stmt1 = $dbh->prepare('SELECT DISTINCT `user_counterparty_id`, `counterparty_id`,  `job_title_id`, `job_title_category`, `subdivision`  FROM `a_user_counterparty`  WHERE `user_id`=?  AND `status`=0 ');
                 $stmt1->execute([ $row->user_id  ]);
            }
            while($row1 = $stmt1->fetch(PDO::FETCH_OBJ)) {
                $job_title_name = '';
                if($row1->job_title_id >0 ){
                    $stmt2 = $dbh->prepare('SELECT  `name`  FROM `a_job_title`  WHERE `job_title_id`=? ');
                    $stmt2->execute([$row1->job_title_id]);
                    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {
                          $job_title_name = $row2->name;
                    }
                }

                $counterparty_name = '';
                if($row1->counterparty_id >0 ){
                    $stmt3 = $dbh->prepare('SELECT  `shortname`, `name`  FROM `a_counterparty`  WHERE `counterparty_id`=? ');
                    $stmt3->execute([$row1->counterparty_id]);
                    if($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {
                        $counterparty_name = $row3->shortname;
                    }
                }
                $jobs[] = [ "user_counterparty_id"=>$row1->user_counterparty_id,   "counterparty_id"=>$row1->counterparty_id, "counterparty_name"=>$counterparty_name, "counterparty_fullname"=>$row3->name,  "job_title_id"=>$row1->job_title_id,  "job_title"=>$job_title_name,   "job_title_category"=>$row1->job_title_category,   "subdivision"=>$row1->subdivision ];
            }
        }
        $rc =  ["user_id"=>$row->user_id, "lastname"=>$row->lastname, "firstname"=>$row->firstname, "middlename"=>$row->middlename,   "date_of_birth"=>$row->date_of_birth, "snils"=>$row->snils,  "jobs"=>$jobs ];

        $is_single = 1;
        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
	        if($row->user_id > 0)
	            $is_single = 0;
        }
      }
    }
    $result = ["status"=>0, "error"=>'', "role"=>$session_role, "action"=>"search",  "result"=>$rc, "userSingle"=>$is_single  ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}



function user_report($user_id) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    $rc =  [];
    if($user_id >0 ) {
	    $stmt = $dbh->prepare('SELECT `course`, `course_id`, `certificate`,  `a_date`, `date_finish`  FROM `a_reports`   WHERE `user_id`=?');
	    $stmt->execute([$user_id]);
	    while($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	        $rc[] =  ["num"=>$row->num, "course"=>$row->course, "course_id"=>$row->course_id, "certificate"=>$row->certificate, "date"=>$row->a_date, "date_finish"=>$row->date_finish, "date_convert"=>formatDate($row->a_date), "date_finish_convert"=>formatDate($row->date_finish)   ];
	    }
    }
    $result = ["role"=>$session_role, "action"=>"report", "userId"=>$user_id, "report"=>$rc ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}




function formatDate($date_point) {
    $datetemp = explode("-",$date_point);
    $yearmy = $datetemp[0];
    $mounthmy = $datetemp[1];
    $daymy = $datetemp[2];
    
    return "$daymy.$mounthmy.$yearmy";
}

