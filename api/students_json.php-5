function user_save($user_id, $email,  $lastname, $firstname, $middlename,   $date_of_birth, $snils, $inn, $phone, $address,  $diplom_filename,  $photo_filename, $sex, $dplom_series, $diplom_number, $diplom_lastname, $citizenship, $level_of_education, $pasport_series, $pasport_number, $pasport_unit_number, $pasport_unit, $comment, $status, $order_id ) {

    global $api_arg, $user_id_session, $session_role, $EmailDomain, $AccountPrefix, $dbh;


    if($lastname=='' ||  $firstname==''){
