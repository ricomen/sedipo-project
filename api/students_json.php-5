}
else if($api_function=='search' ){
    //user_search( intval($api_arg["order_id"]),  intval($api_arg["counterparty_id"]),  $api_arg["lastname"], $api_arg["firstname"], $api_arg["middlename"],  $api_arg["subdivision"], $api_arg["$position"], $api_arg["date_of_birth"],  $api_arg["email"],  $api_arg["snils"] );
    user_search( intval($api_arg["order_id"]), intval($api_arg["counterparty_id"]),  htmlspecialchars($api_arg["lastname"], ENT_QUOTES), htmlspecialchars($api_arg["firstname"], ENT_QUOTES), htmlspecialchars($api_arg["middlename"], ENT_QUOTES), htmlspecialchars($api_arg["snils"], ENT_QUOTES),   intval($api_arg["exclude_user_id"]) );
}
else if($api_function=='link' ){
    user_link(intval($api_arg["order_id"]), intval($api_arg["user_counterparty_id"]), intval($api_arg["objectId"]),  intval($api_arg["item_id"]));
}
else if($api_function=='change' ){
    user_change(intval($api_arg["objectId"]), intval($api_arg["to_user_id"]));
}
else if($api_function=='change_order' ){
    user_change_order(intval($api_arg["item_id"]),  intval($api_arg["to_user_id"]),  intval($api_arg["to_user_counterparty_id"]) );
}
else if($api_function=='report'){
    user_report( intval($api_arg["objectId"]) );
}

else {
    $result = array('POST'=>$_POST, 'GET'=>$_GET, 'SERVER'=>$_SERVER, 'JSON'=>$_JSON);
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}

?>
