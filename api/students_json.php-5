        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
             $job_title_id = $row->job_title_id;
        }
*/

    $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"user_change",   ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
