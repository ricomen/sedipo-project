function user_change_order( $item_id,  $to_user_id,  $to_user_counterparty_id  ) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

//file_put_contents("lst1.txt", print_r([$to_user_counterparty_id, $item_id,  $to_user_id ], true) );
    if($item_id>0 && ( $to_user_id>0 || $to_user_counterparty_id>0)  ) {
 
        if($to_user_counterparty_id<=0 ){
            $stmt = $dbh->prepare('SELECT  `counterparty_id`, `job_title_id`,  `job_title_category`, `subdivision`  FROM  `a_order_users` LEFT JOIN  `a_user_counterparty` USING(`user_counterparty_id`)  WHERE  `item_id`=?  ');
            $stmt->execute([ $item_id  ]);
            if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
                 $to_user_counterparty_id  = 0;
                 $stmt2 = $dbh->prepare('SELECT `user_counterparty_id`  FROM  `a_user_counterparty` WHERE `counterparty_id`=? AND `user_id`=? AND `job_title_id`=? AND `status`=0 ');
                 $stmt2->execute([$row->counterparty_id,  $to_user_id,  $row->job_title_id ]);
                 if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                        $to_user_counterparty_id  = $row2->counterparty_id;
                 }
                 if( $to_user_counterparty_id == 0){
                       $stmt3 = $dbh->prepare('INSERT INTO  `a_user_counterparty`( `user_id`, `counterparty_id`,  `job_title_id`,  `job_title_category`, `subdivision`, `status` )   VALUES( ?, ?, ?, ?, ?,  0 )  ');
                       $stmt3->execute([ $to_user_id, $row->counterparty_id, $row->job_title_id, $row->job_title_category,   $row->subdivision  ]);
                       $to_user_counterparty_id = $dbh->lastInsertId(); 
                 }
            }
        }
        if( $to_user_counterparty_id > 0){
           $stmt3 = $dbh->prepare('UPDATE `a_order_users` SET `user_counterparty_id`=?   WHERE   `item_id`=?  ');
           $stmt3->execute([$to_user_counterparty_id, $item_id ]);
        }

    }
    $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"user_change_order",   ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}



function user_archive($user_id, $user_status) {
    global $api_arg, $user_id_session, $session_role, $customer, $dbh;

    $status = "0";
    $error = '';

    if($user_id >0) {
        if($status==1) {
            $stmt = $dbh->prepare('DELETE FROM `a_order_users` WHERE  `user_id`=? ');
            $stmt->execute([$user_id ]);
        }

	$stmt = $dbh->prepare('UPDATE `a_users` SET `status`=?  WHERE `user_id`=?');
	$stmt->execute([$user_status, $user_id]);
	if(!$stmt) {
            $status = "4";
            $error = 'error 2: '. $dbh->errorInfo()[2];
	}
    }

    $result = ["status"=>$status, "error"=>$error, "role"=>$session_role, "action"=>"user_del", "customerId"=>$customer, "userId"=>$user_id_session];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function user_del($user_id) {
    global $api_arg, $user_id_session, $session_role, $customer, $dbh;

    $status = "0";
    $error = '';

    if($user_id >0) {
            $stmt = $dbh->prepare('SELECT `user_counterparty_id`   FROM `a_user_counterparty`  WHERE `user_id`=?  ');
            $stmt->execute([ $user_id  ]);
            while($row = $stmt->fetch(PDO::FETCH_OBJ)) {
                $stmt2 = $dbh->prepare('DELETE FROM `a_order_users` WHERE  `user_counterparty_id`=? ');
                $stmt2->execute([ $row->user_counterparty_id ]);
            }


            $stmt = $dbh->prepare('DELETE FROM `a_user_counterparty` WHERE  `user_id`=? ');
	    $stmt->execute([$user_id ]);

	    $stmt = $dbh->prepare('DELETE FROM `a_users`  WHERE `user_id`=?');
	    $stmt->execute([$user_id]);

	    if(!$stmt) {
            $status = "4";
	           $error = 'error 2: '. $dbh->errorInfo()[2];
	    }
    }

    $result = ["status"=>$status, "error"=>$error, "role"=>$session_role, "action"=>"user_del", "customerId"=>$customer, "userId"=>$user_id_session];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


