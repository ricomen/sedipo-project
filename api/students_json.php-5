function user_save_counterparty($user_id,  $counterparty_id, $job_title_name, $job_title_category,  $subdivision, $order_id, $user_counterparty_id  ) {
    global $api_arg, $user_id_session, $session_role, $EmailDomain, $AccountPrefix, $dbh;

    $job_title_name = trim($job_title_name);
    
    $job_title_id = 0;
    if(trim($job_title_name) != '' && $user_id>1){
	$count_p = 0;
	$stmt = $dbh->prepare("select `job_title_id` FROM  `a_job_title`  WHERE `name`=?   ");
        $stmt->execute([trim($job_title_name)]);
	if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
	    $count_p = 1;
	    $job_title_id = intval($row->job_title_id);
	}
	if($count_p == 0 && trim($job_title_name) != '' ) {
	    $stmt = $dbh->prepare("INSERT INTO `a_job_title`(`name`) VALUES(?)");
    	    $stmt->execute([trim($job_title_name)]);
	    $job_title_id = intval($dbh->lastInsertId() ); 
	}
    }

    if($job_title_id<=0)
            $job_title_id = 1;

    if($user_counterparty_id==0 && $counterparty_id>0 ){
        $stmt = $dbh->prepare('SELECT `user_counterparty_id` FROM  `a_user_counterparty` WHERE  `user_id`=? AND  `counterparty_id`=? AND  `job_title_id`=?  ');
        $stmt->execute([ $user_id, $counterparty_id, $job_title_id   ]);
        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
             $user_counterparty_id = $row->user_counterparty_id;
        }

    }
    else if($user_counterparty_id==0){
        $stmt = $dbh->prepare('SELECT `user_counterparty_id` FROM  `a_user_counterparty` WHERE  `user_id`=?  AND  `job_title_id`=?  ');
        $stmt->execute([ $user_id,  $job_title_id   ]);
        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
             $user_counterparty_id = $row->user_counterparty_id;
        }
    }

    if($user_counterparty_id==0){
        $p_user_counterparty_id = 0;
        if($user_id>1 && $job_title_id>0){
            $stmt = $dbh->prepare('INSERT INTO  `a_user_counterparty`( `user_id`, `counterparty_id`,  `job_title_id`,  `job_title_category`, `subdivision`, `status` )   VALUES( ?, ?, ?, ?, ?,  0 )  ');
            $stmt->execute([ $user_id, $counterparty_id, $job_title_id, $job_title_category,   trim($subdivision)   ]);
            $p_user_counterparty_id = $dbh->lastInsertId(); 
        }
    }
    else {
        $p_user_counterparty_id = $user_counterparty_id;
    }

    $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"user_counterparty_save",   "result"=>["user_counterparty_id"=>$p_user_counterparty_id] ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function archive_user_counterparty($user_counterparty_id, $status  ) {
    global $api_arg, $user_id_session, $session_role, $EmailDomain, $AccountPrefix, $dbh;

    $stmt = $dbh->prepare('UPDATE  `a_user_counterparty` SET `status`=?  WHERE  `user_counterparty_id`=?   ');
    $stmt->execute([ $status, $user_counterparty_id  ]);


    $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"archive_user_counterparty",   "result"=>["user_counterparty_id"=>$user_counterparty_id] ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function delete_user_counterparty($user_counterparty_id  ) {
    global $api_arg, $user_id_session, $session_role, $EmailDomain, $AccountPrefix, $dbh;

    $stmt = $dbh->prepare('DELETE FROM  `a_user_counterparty`  WHERE  `user_counterparty_id`=?   ');
    $stmt->execute([ $user_counterparty_id   ]);


    $result = ["status"=>0, "error"=>'',  "role"=>$session_role, "action"=>"delete_user_counterparty",   "result"=>["user_counterparty_id"=>$user_counterparty_id] ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}



