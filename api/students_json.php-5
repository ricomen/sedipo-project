function mb_ucfirst($arg_w, $charset = "utf-8") {
    $word = trim(htmlspecialchars($arg_w, ENT_QUOTES));
	return mb_strtoupper(mb_substr($word, 0, 1, $charset), $charset).mb_substr($word, 1, mb_strlen($word, $charset)-1, $charset);
}


function snils_format($snils) {
    //$snils_a = preg_split('/[ ,]+/', trim($snils), -1);
    //return $snils_a[0]. '-' . $snils_a[1]. '-' . $snils_a[2]. ' ' . $snils_a[3];

    $snils_a = str_split(str_replace(' ', '', str_replace('-', '',  trim($snils))), 1);
    return $snils_a[0].$snils_a[1].$snils_a[2]. '-' . $snils_a[3].$snils_a[4].$snils_a[5]. '-' . $snils_a[6].$snils_a[7].$snils_a[8]. ' ' . $snils_a[9].$snils_a[10];
}


