function cohort_make($order_id, $counterparty_id ) {
    global $api_arg, $user_id_session, $session_role,  $dbh;
    global $page_size;
    global $HoursPerDay;


        $group_status = 7; /*Комплектование групп*/ 	
        $stmt = $dbh->prepare('SELECT `order_id`, `date_order`, `number`, `status_id`, `counterparty_id`, `date_begin`, `date_end`   FROM `a_order`   WHERE `order_id`=?');
        $stmt->execute([$order_id]);
        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	        $date_order = $row->date_order;
	        $number = $row->number;
	        $order_status_id = $row->status_id;
	        $order_counterparty_id = $row->counterparty_id;
	        $date_begin = $row->date_begin;
	        $date_end = $row->date_end;
        }

            $i = 1;
            $prev_id = 0;
	    $stmt = $dbh->prepare('SELECT DISTINCT `a_order_course`.`item_id`, `a_order_course`.`course_id`, `a_order_course`.`group_number`,  `a_course_category`.`consulting`, `a_course`.`shortname`, `group_number`   FROM  `a_order_users` LEFT JOIN `a_order_course` USING(`item_id`)  LEFT JOIN `a_course` USING(`course_id`)  LEFT JOIN `a_course_category` USING(`category_id`) LEFT JOIN  `a_user_counterparty`  USING(`user_counterparty_id`)  LEFT JOIN   `a_users` USING(`user_id`)   WHERE `order_id`=? AND `a_order_course`.`course_id`>0 AND `a_user_counterparty`.`counterparty_id`=?  AND `a_users`.`status`=0 AND `a_user_counterparty`.`status`=0   ORDER BY `a_course`.`shortname`   ');
	    $stmt->execute([$order_id, $counterparty_id]);
	    while($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	        if(intval($row->course_id)<=0)
	                continue;

                $consulting = 0;
                $count_cohort = 0;
                $i_cohort_id = 0;
                $i_group_number = $row->group_number;
                if( $i_group_number == 1 )
                         $i_group_number = 0;

                $stmt2 = $dbh->prepare('SELECT `cohort_id`   FROM  `a_order_users`  LEFT JOIN `a_order_course` USING(`item_id`)   WHERE `order_id`=? AND `course_id`=? AND `group_number`=? AND  `cohort_id`>0  ORDER BY `a_order_users`.`certificate_num` ');
                $stmt2->execute([$order_id, $row->course_id, $i_group_number]);
                if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
	            //$count_cohort = $row2->count;
	            $i_cohort_id = $row2->cohort_id;
	        }
//file_put_contents("lst.txt", print_r($i_cohort_id, true) );
                if($i_cohort_id == 0) {
                    $consulting = $row->consulting;

//$p_group_id =0;
                    $cohort_name = substr($date_order, 2) .'/'.  $number .'.'.  $i;
                    $protocol_num = 1;
                    //$stmt2 = $dbh->query('LOCK TABLES   `a_cohort`  WRITE');
                    $stmt2 = $dbh->prepare('SELECT max(`protocol_num`)  as `last_protocol_num`    FROM `a_cohort` WHERE `date_num`=?  ');
                    $stmt2->execute([ $date_order ]);
                    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                            $protocol_num = $row2->last_protocol_num + 1;
                    }

                    $prev_id_i = intval($prev_id);
                    if($consulting == 1)
                            $prev_id_i = 0; 

                    $stmt2 = $dbh->prepare("INSERT INTO `a_cohort`(`counterparty_id`,  `name`,  `course_id`, `group_number`,   `protocol_num`,    `date_num`, `prev_id`  ) VALUES ( ?, ?, ?, ?, ?, ?, ? )");
                    $stmt2->execute([ $counterparty_id,  $cohort_name,  $row->course_id,  $row->group_number,   $protocol_num,   $date_order, $prev_id_i ]);  
                    $p_cohort_id = $dbh->lastInsertId(); 

//$stmt2 = $dbh->prepare('UPDATE `a_cohort`  SET   `lstream_id`=?  WHERE `cohort_id`=?');
//$stmt2->execute([ $p_cohort_id,    $p_cohort_id  ]);

//$stmt2 = $dbh->prepare("INSERT INTO `a_lstream`( `lstream_id`,  `name`,  `course_id`,  `date_begin`, `date_end`, `date_protocol`, `date_begin2`, `protocol_num`,  `directive_num`,  `chairman`, `teachers_commission`,  `commission_id`,  `date_num`, `prev_id`  ) VALUES ( ?,  ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ? )");
//$stmt2->execute([ $p_cohort_id,  $cohort_name,  $row->course_id,  $date_begin_g, $date_end_g, $date_protocol_g, $date2, $protocol_num, $directive,  $chairman, $teachers_commission, $commission_id,   $date_order, $prev_id_i ]);  
//$p_lstream_id = $dbh->lastInsertId(); 

                    $stmt2 = $dbh->query('UNLOCK TABLES');
                
                    if($p_cohort_id >0 ) {

                           $stmt3 = $dbh->prepare('UPDATE  `a_order_course` SET  `cohort_id`=?  WHERE `item_id`=? AND `course_id`=?  ');
                           $stmt3->execute([ $p_cohort_id,  $row->item_id,  $row->course_id ]);
                    }
            }
            else {
                /*$certificate_num = 0;
                $stmt2 = $dbh->prepare('SELECT   DISTINCT  `user_id`, `certificate_num`, `user_lock`, `rank_of_profession`, `variation`  FROM  `a_order_users`   WHERE `order_id`=? AND `course_id`=?  AND `cohort_id`=0  ORDER BY `certificate_num` ');
                $stmt2->execute([$order_id,  $row->course_id]);
                while($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                    $certificate_num = $certificate_num +1;

                        
                    $stmt3 = $dbh->prepare('DELETE FROM `a_order_users` WHERE `order_id`=? AND  `course_id`=? AND `user_id`=? AND `cohort_id`=? ');
                    $stmt3->execute([$order_id, $row->course_id, $row2->user_id, $i_cohort_id ]);
                        
                        $record_exist = 0;    
                        $stmt3 = $dbh->prepare('SELECT count(*) as `count`  FROM `a_order_users` WHERE `order_id`=? AND  `course_id`=? AND `user_id`=? AND `cohort_id`=0 ');
                        $stmt3->execute([$order_id, $row->course_id, $row2->user_id]);
                        if($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {
	                        if($row3->count > 0)
                                    $record_exist = 1;    
                        }

                        if($record_exist>0){
                            $stmt3 = $dbh->prepare('INSERT INTO `a_order_users`(`order_id`, `course_id`, `user_id`, `cohort_id`, `certificate_num`, `user_lock`, `rank_of_profession`, `variation` ) VALUES ( ?, ?, ?, ?, ?, ?, ?, ? )');
                            $stmt3->execute([$order_id, $row->course_id, $row2->user_id, $i_cohort_id, $certificate_num , $row2->user_lock, $row2->rank_of_profession, $row2->variation ]);

                            $stmt3 = $dbh->prepare('UPDATE  `a_order_course` SET  `cohort_id`=?, `certificate_num`=?  WHERE `item_id`=? AND `course_id`=? AND  `rank_of_profession`=? AND `variation`=? ');
                            $stmt3->execute([ $i_cohort_id, $certificate_num, $row->item_id, $row->course_id, $row2->rank_of_profession, $row2->variation ]);
                        }
	           }*/
                   $stmt3 = $dbh->prepare('UPDATE  `a_order_course` SET  `cohort_id`=?  WHERE `item_id`=? AND `course_id`=?  ');
                   $stmt3->execute([ $i_cohort_id,  $row->item_id,  $row->course_id ]);
            }
	        $i = $i+1;
            $date_begin_g = date('Y-m-d', strtotime($date_end_g) +  (60*60*24));
            if($consulting == 0)
                    $prev_id = $p_cohort_id;            
        }
}




function cohort_list($order_id, $make, $counterparty_id, $date1, $date2, $course, $group,  $status,  $page) {
    global $api_arg, $user_id_session, $session_role,  $dbh;
    global $page_size;
    global $HoursPerDay;

    $offset=0;
    if( $page>1 ){
	    $offset = intval($page-1)*$page_size;
    }
    $num_pages = 0;

    $g_list = [];
    $counterparty_title_shortname = '';

    $addsearch = '';
    if($counterparty_id>0){
        $addsearch =  ' AND `counterparty_id`=' . $counterparty_id . ' ';
    }
    if($date1!=''){
        $addsearch = $addsearch . ' AND `a_lstream`.`date_begin`>=' . $dbh->quote($date1) . ' ';
    }
    if($date2!=''){
        $addsearch = $addsearch . ' AND `a_lstream`.`date_end`<=' . $dbh->quote($date2) . ' ';
    }
    if($course!=''){
        $addsearch = $addsearch . ' AND `a_course`.`shortname` LIKE \'%' . addslashes(trim($course)) . '%\' ';
    }
    if($group!=''){
        $addsearch = $addsearch . ' AND `a_cohort`.`name` LIKE \'%' . addslashes(trim($group)) . '%\' ';
    }
    //if($status>0){
    //    $addsearch = $addsearch . ' AND `a_cohort`.`status_id`=' . $status . ' ';
    //}


    $status_id = 1;
    $date_order = '';
    $a_counterparty_id = 0;
    $stmt = $dbh->prepare('SELECT  `date_order`, `number`, `status_id`, `counterparty_id`, `date_begin`, `date_end`   FROM `a_order`   WHERE `order_id`=?');
    $stmt->execute([$order_id]);
    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
        $status_id = $row->status_id;
        $date_order = $row->date_order;
        $a_counterparty_id = $row->counterparty_id;
    }
    if($a_counterparty_id>0){
        $stmt2 = $dbh->prepare('SELECT `name`, `shortname` FROM  `a_counterparty`   WHERE `counterparty_id`=? ');
        $stmt2->execute([$a_counterparty_id]);
        if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
             $counterparty_title_shortname = $row2->shortname;
        }
    }

    $count = 0;
    if($order_id>0 && $make==1 && $status_id>=7 ){
	    $stmt = $dbh->prepare('SELECT count(*) as `count`   FROM  `a_order_users` LEFT JOIN  `a_order_course` USING(`item_id`)   WHERE `a_order_users`.`order_id`=?  AND `a_order_course`.`cohort_id`>0 ');
	    $stmt->execute([$order_id]);
	    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	        $count = $row->count;
	    }
    }

    //if($order_id>0 && $make==1){
    if($order_id>0 && $make==1 && ($status_id<7 || $count==0)){
        cohort_make($order_id, $a_counterparty_id ); 
    }


    if($order_id>0) { 
    	    //$stmt = $dbh->prepare('SELECT DISTINCT  `cohort_id`, `lstream_id`, `a_cohort`.`name`, `a_cohort`.`status_id`, `a_order_users`.`order_id`,  `a_course`.`shortname` as `course_name`,  `a_course`.`course_id`, `a_course`.`hours`, LENGTH(`protocol_html`) as `protocol_html_length`, `upload_certificate1`, `upload_certificate2`, `upload_protocol`   FROM `a_cohort` LEFT JOIN `a_course` USING(`course_id`)  LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)  LEFT JOIN `a_order` USING(`order_id`)  WHERE `order_id`=?  '.$addsearch.' ORDER BY `cohort_id`  LIMIT '.$page_size.'  OFFSET  ' . "$offset");
    	    $stmt = $dbh->prepare('SELECT DISTINCT  `cohort_id`, `lstream_id`, `a_cohort`.`name`, `a_cohort`.`status_id`, `a_order_users`.`order_id`, `a_order_course`.`course_id`,   LENGTH(`protocol_html`) as `protocol_html_length`, `upload_certificate`,  `modify_certificate1`, `modify_certificate2`, `upload_protocol`, `modify_protocol`   FROM `a_cohort`  LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)  LEFT JOIN `a_order` USING(`order_id`) LEFT JOIN `a_lstream` USING(`lstream_id`) LEFT JOIN `a_course` ON `a_cohort`.`course_id`=`a_course`.`course_id`  WHERE `order_id`=?  '.$addsearch.' ORDER BY `a_cohort`.`name` DESC  LIMIT '.$page_size.'  OFFSET  ' . "$offset");
	    $stmt->execute([$order_id]);
    }
    else {
	    //$stmt = $dbh->prepare( 'SELECT DISTINCT `cohort_id`, `lstream_id`,  `a_cohort`.`name`, `a_cohort`.`status_id`, `a_order_users`.`order_id`,  `a_course`.`shortname` as `course_name`,  `a_course`.`course_id`, `a_course`.`hours`, LENGTH(`protocol_html`) as `protocol_html_length`, `upload_certificate1`, `upload_certificate2`, `upload_protocol`   FROM `a_cohort` LEFT JOIN `a_course` USING(`course_id`)  LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)   LEFT JOIN `a_order` USING(`order_id`)  WHERE `order_id`>0  '.$addsearch.' ORDER BY `cohort_id`  LIMIT '.$page_size.'  OFFSET  ' . "$offset");
	    $stmt = $dbh->prepare( 'SELECT DISTINCT `cohort_id`, `lstream_id`,  `a_cohort`.`name`, `a_cohort`.`status_id`, `a_order_users`.`order_id`, `a_order_course`.`course_id`,  LENGTH(`protocol_html`) as `protocol_html_length`, `upload_certificate`,  `modify_certificate1`, `modify_certificate2`, `upload_protocol`, `modify_protocol`   FROM `a_cohort`   LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)   LEFT JOIN `a_order` USING(`order_id`) LEFT JOIN `a_lstream` USING(`lstream_id`) LEFT JOIN `a_course` ON `a_cohort`.`course_id`=`a_course`.`course_id`  WHERE `order_id`>0  '.$addsearch.' ORDER BY `a_cohort`.`name` DESC  LIMIT '.$page_size.'  OFFSET  ' . "$offset");
	    $stmt->execute([]);
    }
    while($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	    $group_count = 0;
	    $date2 = date('Y-m-d', strtotime($row->date_end) - $days * (60*60*24));

	    $stmt2 = $dbh->prepare('SELECT count(*) as `count` FROM  `a_order_course` LEFT JOIN `a_order_users` USING(`item_id`)   WHERE `cohort_id`=? AND `user_counterparty_id`>0 ');
	    $stmt2->execute([$row->cohort_id]);
	    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
	        $group_count = $row2->count;
	    }

            $scheduler_count = 0;
	    $stmt2 = $dbh->prepare('SELECT   count(*) as `count`  FROM `a_cohort_scheduler`   WHERE `lstream_id`=?');
	    $stmt2->execute([$row->lstream_id]);
	    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
	        $scheduler_count = $row2->count;
	    }


            $counterparty_shortname = '';
	    $stmt2 = $dbh->prepare('SELECT `name`, `shortname` FROM  `a_order`  LEFT JOIN `a_counterparty`  USING(`counterparty_id`)  WHERE `order_id`=? ');
	    $stmt2->execute([$row->order_id]);
	    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
	        $counterparty_shortname = $row2->shortname;
	    }

            $date_begin = '';
            $date_end   = '';
            if($row->lstream_id > 0 ){
                 $stmt2 = $dbh->prepare('SELECT `date_begin`, `date_end` FROM  `a_lstream`   WHERE `lstream_id`=? ');
	         $stmt2->execute([$row->lstream_id]);
	         if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                      $date_begin = $row2->date_begin;
                      $date_end   = $row2->date_end;
	         }
            }

	    $stmt2 = $dbh->prepare('SELECT   `protocol_template`, `certificate1_template`, `certificate2_template`, `certificate1_name`, `certificate2_name`,  `a_course`.`category_id`, `a_course_category`.`consulting`,  `a_course`.`shortname` as `course_name`, `a_course`.`hours`     FROM  `a_cohort` LEFT JOIN `a_course` USING(`course_id`) LEFT JOIN `a_course_category` USING(`category_id`)   WHERE `cohort_id`=? ');
	    $stmt2->execute([$row->cohort_id]);
	    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  	        
                $days =  intval(intval($row2->hours) / $HoursPerDay + 0.9) + intval(intval(intval($row2->hours) / $HoursPerDay  + 0.9) / 5 )*2;
	        $g_list[] =  [ "name"=>$row->name,  "status_id"=>$row->status_id,   "count"=>$group_count,  "scheduler_count"=>$scheduler_count, "cohort_id"=>$row->cohort_id, "lstream_id"=>$row->lstream_id, "course_id"=>$row->course_id,  "course_name"=>$row2->course_name,    "category_id"=>$row2->category_id, "consulting"=>$row2->consulting,  "protocol_template"=>$row2->protocol_template, "certificate1_template"=>$row2->certificate1_template, "certificate2_template"=>$row2->certificate2_template, "certificate1_name"=>$row2->certificate1_name,  "certificate2_name"=>$row2->certificate2_name,   "counterparty_shortname"=>$counterparty_shortname,   "title_hours"=>intval($row2->hours),  "hours"=>intval($row2->hours), "days"=>$days,   "protocol_template"=>$row2->protocol_template, "date_begin"=>$date_begin, "date_end"=>$date_end,  "protocol_html_length"=>intval($row->protocol_html_length),  "upload_certificate"=>$row->upload_certificate, "modify_certificate1"=>$row->modify_certificate1, "modify_certificate2"=>$row->modify_certificate2, "upload_protocol"=>$row->upload_protocol, "modify_protocol"=>$row->modify_protocol  ];
	    }
    }
    if($order_id>0) { 
    	$stmt0 = $dbh->prepare('SELECT count(DISTINCT `a_cohort`.`cohort_id` ) as `count`  FROM  `a_cohort` LEFT JOIN `a_course` USING(`course_id`)   LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)   LEFT JOIN `a_order` USING(`order_id`)  LEFT JOIN `a_lstream` USING(`lstream_id`)   WHERE `order_id`=?  '.$addsearch);
        $stmt0->execute([$order_id]);
    }
    else {
        $stmt0 = $dbh->query('SELECT  count(DISTINCT `a_cohort`.`cohort_id` )  as `count`   FROM  `a_cohort` LEFT JOIN `a_course` USING(`course_id`)   LEFT JOIN `a_order_course` USING(`cohort_id`)  LEFT JOIN `a_order_users` USING(`item_id`)   LEFT JOIN `a_order` USING(`order_id`)  LEFT JOIN `a_lstream` USING(`lstream_id`)  WHERE 1  '.$addsearch  );
    }
    if($row0 = $stmt0->fetch(PDO::FETCH_OBJ)) {  
	$members = $row0->count;
    }
    $num_pages = intval(($members+0.5)/$page_size+1);
    if( $page > $num_pages ){
	    $page = $num_pages;
    }


    $result = ["role"=>$session_role, "action"=>"list",  "list"=>$g_list,  "counterparty_title_shortname"=>$counterparty_title_shortname,   "search"=>$addsearch, "numPages"=>$num_pages, "page"=>$page ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}




function cohort_object($cohort_id) {
    global $api_arg, $user_id_session, $session_role,  $dbh;
    global $HoursPerDay;

    $rc =  ["cohort_id"=>$cohort_id,  "name"=>''  ];
    $days = 0;
    $scheduler = [];
    if($cohort_id >0 ) {
	    $stmt = $dbh->prepare('SELECT   `a_cohort`.`name`, `a_cohort`.`course_id`,  `prev_id`, `lstream_id`,  `variation`, `order_id`   FROM `a_cohort`  LEFT JOIN `a_order_course` USING(`cohort_id`) LEFT JOIN `a_order_users` USING(`item_id`)   WHERE `a_cohort`.`cohort_id`=?');
	    $stmt->execute([$cohort_id]);
	    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
                if($row->lstream_id >0 ){
                    $date_begin = '';
                    $date_end = '';
                    $date_protocol = '';
                    $main_teacher = 0;
                    $chairman = '';
                    $teachers_commission = '';
                    $directive_num = '';
                    $main_teacher_name = ''; 
                    $stmt2 = $dbh->prepare('SELECT   `date_begin`, `date_end`, `date_protocol`, `main_teacher`,  `commission_id`, `directive_num`   FROM `a_lstream`   WHERE `lstream_id`=?');
                    $stmt2->execute([ $row->lstream_id ]);
                    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                           $date_begin = $row2->date_begin;
                           $date_end = $row2->date_end;
                           $date_protocol = $row2->date_protocol;
                           $main_teacher = $row2->main_teacher;
                           $commission_id = $row2->commission_id;
                           $directive_num = $row2->directive_num;
                    }
                    $stmt3 = $dbh->prepare('SELECT  `lastname`, `firstname`, `middlename`   FROM  `a_teacher`     WHERE `user_id`=?');
                    $stmt3->execute([$row->main_teacher]);
                    if($row3 = $stmt3->fetch(PDO::FETCH_OBJ)) {  
                            $main_teacher_name = $row3->lastname. ' ' . $row3->firstname. ' ' .$row3->middlename ;
                    }

                    $stmt2 = $dbh->prepare('SELECT DISTINCT  `date`, `work`   FROM `a_cohort_scheduler`   WHERE `lstream_id`=? ORDER BY `date` ');
                    $stmt2->execute([$row->lstream_id]);
                    while($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
                         $scheduler[] = ["date"=>$row2->date, "work"=>$row2->work];
                    }
                }

                $stmt1 = $dbh->prepare('SELECT  `category_id`,   `name` as `course_name`, `shortname` as `course_shortname`,  `hours`, `hours_l`, `hours_p`, `hours_i`, `hours_c`,  `hours_add`, `hours_l_add`, `hours_p_add`, `hours_i_add`, `hours_c_add`    FROM  `a_course`  WHERE `course_id`=?');
	        $stmt1->execute([ $row->course_id  ]);
	        if($row1 = $stmt1->fetch(PDO::FETCH_OBJ)) {
                   $course_name = $row1->course_name;
                   $course_shortname = $row1->course_shortname;
                   $category = $row1->category_id;
                   $title_hours = intval($row1->hours);
                   if($row->variation <= 1){
                        $hours = intval($row1->hours);
                        $hours_l = $row1->hours_l;
                        $hours_p = $row1->hours_p;
                        $hours_i = $row1->hours_i;
                        $hours_c = $row1->hours_c;
                   }
                   else if($row->variation == 2){
