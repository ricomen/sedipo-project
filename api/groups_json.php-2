function cohort_scheduler_list($cohort_id){
    global $api_arg, $user_id_session, $session_role,  $dbh;
    global $HoursPerDay;

    $rc =  [];
    if($cohort_id >0 ) {
            $course_id = 0;
            $lstream_id = -1;
	    $stmt = $dbh->prepare('SELECT `a_order_course`.`course_id`, `lstream_id`  FROM `a_order_course` LEFT JOIN `a_cohort` USING(`cohort_id`)   WHERE `a_order_course`.`cohort_id`=?');
	    $stmt->execute([$cohort_id]);
	    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	        $course_id = $row->course_id;
	        $lstream_id = $row->lstream_id;
	    }
            if( $course_id>0 && $lstream_id==0 ){
                    $stmt = $dbh->prepare('SELECT DISTINCT  `a_cohort`.`lstream_id`, `date_begin`, `date_end`, `date_protocol`, `a_lstream`.`name`  FROM `a_order_course` LEFT JOIN `a_cohort` USING(`cohort_id`) LEFT JOIN `a_lstream` USING(`lstream_id`)   WHERE `a_cohort`.`lstream_id`>0 AND `date_begin` IS NOT NULL   AND  `a_order_course`.`course_id`=?  ORDER BY `date_begin` DESC ');
                    $stmt->execute([$course_id]);
                    while($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
                            $rc[] = [ "lstream_id"=>$row->lstream_id, "date_begin"=>$row->date_begin,  "date_end"=>$row->date_end,  "date_protocol"=>$row->date_protocol,  "name"=>$row->name ];
                    }
            }
    }
    $result = ["status"=>"0", "error"=>'', "role"=>$session_role, "action"=>"cohort_scheduler_object", "cohort_id"=>$cohort_id, "list"=>$rc ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


