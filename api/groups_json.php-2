function cohort_create( $name,  $course_id, $category, $date_begin, $date_end, $date_protocol, $date_order, $main_teacher_id, $chairman, $teacher_c   ) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    if($date_begin == '')
         $date_begin = date('Y-m-d');

    if($date_end == '')
         $date_end = date('Y-m-d');
         
    if($date_protocol == '' || $date_protocol == '0000-00-00')
        $date_protocol = $date_end;

    if($group_id >0 ) {
        if($chairman == '' && $teacher_c == '') {
            $stmt = $dbh->prepare('SELECT `chairman`, `teachers_commission`  FROM `a_course` LEFT JOIN `a_course_category` USING(`category_id`) WHERE  `a_course`.`course_id`=? ');
	        $stmt->execute([$course_id]);
	        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {  
	            $chairman = $row->chairman;
	            $teacher = $row->teachers_commission;
	            //$directive_num  = $row->directive_num;
	        }
        }     

        $protocol_num = 1;
        $stmt2 = $dbh->query('LOCK TABLES   `a_cohort`  WRITE');
        $stmt2 = $dbh->prepare('SELECT max(`protocol_num`)  as `last_protocol_num`    FROM `a_cohort` WHERE date_protocol=? ');
        $stmt2->execute([ $date_protocol ]);
	    if($row2 = $stmt2->fetch(PDO::FETCH_OBJ)) {  
	            $protocol_num = $row2->last_protocol_num + 1;
	    }
            $stmt2 = $dbh->prepare('INSERT INTO `a_cohort`( `name`,  `course_id`, `category`,  `date_begin`, `date_end`, `date_protocol`,`main_teacher`, `protocol_num`, `chairman`, `teachers_commission`, `enterprise_manager`, `enterprise_manager2`, `date_num` ) VALUES ( ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ? )');
	    $stmt2->execute([ $name,  $course_id, $category, $date_begin, $date_end, $date_protocol, $main_teacher_id, $protocol_num,  $chairman, $teacher_c, $enterprise_manager, $enterprise_manager2, $date_order ]);
	    $cohort_id = $dbh->lastInsertId(); 
        $stmt2 = $dbh->query('UNLOCK TABLES');
	    
    }

    if($cohort_id>0)
	    $result = ["status"=>"0", "error"=>'', "role"=>$session_role, "action"=>"cohort_save", "userId"=>$user_id_session, "result"=>$cohort_id ];
    else
        $result = ["status"=>"1", "error"=>'Ошибка записи в базу данных', "role"=>$session_role, "action"=>"cohort_save", "userId"=>$user_id_session, "result"=>0 ];

    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}


function cohort_del($cohort_id) {
    global $api_arg, $user_id_session, $session_role,  $dbh;

    if($cohort_id >0 ) {
            $stmt = $dbh->prepare('UPDATE  `a_order_course` SET  `cohort_id`=0  WHERE `cohort_id`=?  ');
            $stmt->execute([ $cohort_id ]);
	    
            $stmt = $dbh->prepare('DELETE FROM  `a_cohort_scheduler`  WHERE `cohort_id`=?');
            $stmt->execute([ $cohort_id  ]);

            $lstream_id = 0;
	    $stmt = $dbh->prepare('SELECT  `lstream_id`  FROM `a_cohort`   WHERE `cohort_id`=? ');
	    $stmt->execute([$cohort_id]);
	    if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
                 $lstream_id = $row->lstream_id;
	    }
 
            if($lstream_id >0 ){
                $stmt = $dbh->prepare('SELECT count(*) as `count`  FROM `a_cohort`  WHERE  `lstream_id`=? ');
	        $stmt->execute([$lstream_id]);
	        if($row = $stmt->fetch(PDO::FETCH_OBJ)) {
	            if($row->count <= 1){
                        $stmt2 = $dbh->prepare('DELETE FROM   `a_lstream`   WHERE  `lstream_id`=?  ');
                        $stmt2->execute([$lstream_id]);

                        $stmt2 = $dbh->prepare('DELETE FROM   `a_cohort_scheduler`   WHERE  `lstream_id`=?  ');
                        $stmt2->execute([$lstream_id]);
	            }
	        }
	    }     

	    $stmt = $dbh->prepare('DELETE FROM  `a_cohort`   WHERE `cohort_id`=? ');
	    $stmt->execute([$cohort_id]);
    }

    $result = ["status"=>0, "error"=>'', "role"=>$session_role, "action"=>"group_del" ];
    echo json_encode($result, JSON_UNESCAPED_UNICODE);
}




